# build output
dist/

# Astro (generated types, content cache, etc.)
.astro/

# dependencies
node_modules/
.pnpm-store/

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment — keep secrets out of git; commit `.env.example` as a template
.env*
!.env.example

# keys & credentials (never commit)
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.json
service-account*.json

# deployment / host CLI metadata (sensitive or machine-specific)
.vercel/
.netlify/
.wrangler/
.supabase/

# caches & tooling
.cache/
.eslintcache
*.tsbuildinfo

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# JetBrains
.idea/

# VS Code — uncomment if you do NOT want to share workspace settings with the team
.vscode/
