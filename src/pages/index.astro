---
export const prerender = true;

import { Picture } from 'astro:assets';
import { HOME_PAGE_TITLE, SITE_DEFAULT_DESCRIPTION } from '../config/site';
import SiteLayout from '../layouts/SiteLayout.astro';
import TourCard from '../components/TourCard.astro';
import HeroCarousel from '../components/vue/HeroCarousel.vue';
import type { HeroPanel } from '../components/vue/HeroCarousel.vue';
import FAQAccordion from '../components/vue/FAQAccordion.vue';
import { getFeaturedTours } from '../lib/tours';
import { getAllDestinations } from '../lib/destinations';
import { ABOUT } from '../data/about';
import { FAQ_ITEMS } from '../data/faq';
import { HERO_IMAGE } from '../data/hero-image';
import { faqPageJsonLd, organizationJsonLd, websiteJsonLd } from '../lib/seo';

const siteUrl = Astro.site ? String(Astro.site).replace(/\/$/, '') : '';
const jsonLd = siteUrl
	? [organizationJsonLd(siteUrl), websiteJsonLd(siteUrl), faqPageJsonLd(FAQ_ITEMS.slice(0, 4))]
	: faqPageJsonLd(FAQ_ITEMS.slice(0, 4));

const featuredTours = getFeaturedTours();
const allDestinations = getAllDestinations();
const destinationStrip = allDestinations.slice(0, 6);
const faqPreview = FAQ_ITEMS.slice(0, 4);

const heroPanels: HeroPanel[] = [
	{
		id: 'tours',
		icon: 'sailboat',
		heading: 'The Adriatic from the water, the way it should be',
		subtext:
			'Group departures along the Dalmatian coast. Small boats, real skippers, no tourist conveyor belts.',
		ctaLabel: 'Browse all tours',
		ctaHref: '/tours',
		dotLabel: 'Show all tours',
	},
	{
		id: 'charter',
		icon: 'anchor',
		heading: 'Your own boat, your own itinerary',
		subtext:
			'Private charters for two or twenty. Set the route, set the pace, skip the crowds entirely.',
		ctaLabel: 'Plan a private charter',
		ctaHref: '/contact?tour=create-perfect-day-private',
		dotLabel: 'Show private charter',
	},
];
---

<SiteLayout title={HOME_PAGE_TITLE} description={SITE_DEFAULT_DESCRIPTION} solidNav={false} booking jsonLd={jsonLd}>
	<main id="main">
		<div class="page home-page">
			<HeroCarousel client:idle panels={heroPanels}>
				<Picture
					slot="media"
					src={HERO_IMAGE.src}
					alt={HERO_IMAGE.alt}
					formats={['avif', 'webp']}
					widths={[768, 1280, 1920, 2560, 3840]}
					sizes="100vw"
					layout="none"
					priority
					class="hero-banner"
					pictureAttributes={{ class: 'hero-banner-picture' }}
				/>
				<div class="hero-badge">
					<i class="ti ti-shield-check" aria-hidden="true"></i>
					Free cancellation up to 48h
				</div>
			</HeroCarousel>

			<div class="page-shell">
				<section aria-labelledby="featured-heading">
					<div class="section-header">
						<h2 id="featured-heading" class="section-title">Popular tours</h2>
						<a class="section-link" href="/tours">See all tours →</a>
					</div>
					<div class="cards-scroll">
						{
							featuredTours.map((tour) => (
								<TourCard tour={tour} featured={tour.featured} />
							))
						}
					</div>
				</section>

				<section aria-labelledby="destinations-heading">
					<div class="section-header">
						<h2 id="destinations-heading" class="section-title">Where we go</h2>
						<a class="section-link" href="/destinations">All destinations →</a>
					</div>
					<div class="dest-grid">
						{
							destinationStrip.map((dest) => (
								<a class="dest-card" href={`/destinations/${dest.slug}`}>
									<i class={`ti ti-${dest.icon} bg-icon`} aria-hidden="true" />
									<h3 class="dest-name">{dest.name}</h3>
									<span class="dest-count">
										{dest.tourSlugs.length} tour{dest.tourSlugs.length === 1 ? '' : 's'}
									</span>
								</a>
							))
						}
					</div>
				</section>

				<section aria-labelledby="how-heading">
					<div class="section-header">
						<h2 id="how-heading" class="section-title">How it works</h2>
					</div>
					<div class="steps">
						<div class="step-card">
							<div class="step-num">1</div>
							<p class="step-title">Choose a tour</p>
							<p class="step-desc">
								Browse by destination, duration, or activity. Group or private — your call.
							</p>
						</div>
						<div class="step-card">
							<div class="step-num">2</div>
							<p class="step-title">Pick your date</p>
							<p class="step-desc">Check availability and choose a departure that suits your schedule.</p>
						</div>
						<div class="step-card">
							<div class="step-num">3</div>
							<p class="step-title">Book securely</p>
							<p class="step-desc">Pay online via secure checkout. Instant confirmation to your inbox.</p>
						</div>
						<div class="step-card">
							<div class="step-num">4</div>
							<p class="step-title">Show up and sail</p>
							<p class="step-desc">
								Meet your captain at Riva stand 14. Everything else is taken care of.
							</p>
						</div>
					</div>
				</section>

				<section aria-labelledby="types-heading">
					<div class="section-header">
						<h2 id="types-heading" class="section-title">Group or private?</h2>
					</div>
					<div class="types-grid">
						<div class="type-card">
							<div class="type-icon type-icon--group">
								<i class="ti ti-users" aria-hidden="true"></i>
							</div>
							<p class="type-title">Group tour</p>
							<p class="type-desc">
								Join a small shared departure — max 12 guests. Great for solo travellers, couples, and
								anyone who likes meeting people on the water.
							</p>
							<div class="type-features">
								<span class="type-feat"><i class="ti ti-circle-check" aria-hidden="true"></i> From €89 per person</span>
								<span class="type-feat"><i class="ti ti-circle-check" aria-hidden="true"></i> Fixed departures, daily</span>
								<span class="type-feat"><i class="ti ti-circle-check" aria-hidden="true"></i> Licensed skipper on every route</span>
							</div>
							<a class="type-cta" href="/tours">Browse group tours</a>
						</div>
						<div class="type-card featured">
							<div class="type-icon type-icon--private">
								<i class="ti ti-crown" aria-hidden="true"></i>
							</div>
							<p class="type-title">Private charter</p>
							<p class="type-desc">
								The whole boat is yours. Choose your route, set your pace, bring your own food and music.
								Ideal for families, celebrations, and corporate groups.
							</p>
							<div class="type-features">
								<span class="type-feat"><i class="ti ti-circle-check" aria-hidden="true"></i> Quoted per boat and season</span>
								<span class="type-feat"><i class="ti ti-circle-check" aria-hidden="true"></i> Fully customisable route</span>
								<span class="type-feat"><i class="ti ti-circle-check" aria-hidden="true"></i> Flexible departure time</span>
							</div>
							<a class="btn-primary btn-primary--compact" href="/contact?tour=create-perfect-day-private">
								Plan a private charter
							</a>
						</div>
					</div>
				</section>

				<section class="trust-bar" aria-label="Why guests trust us">
					{
						ABOUT.trustStats.map((stat) => (
							<div class="trust-item">
								<i class={`ti ti-${stat.icon}`} aria-hidden="true" />
								<span class="trust-num">{stat.value}</span>
								<span class="trust-label">{stat.label}</span>
							</div>
						))
					}
				</section>

				<section aria-labelledby="faq-heading">
					<div class="section-header">
						<h2 id="faq-heading" class="section-title">Common questions</h2>
						<a class="section-link" href="/faq">All FAQs →</a>
					</div>
					<FAQAccordion client:visible items={faqPreview} />
				</section>

				<section class="cta-band" aria-labelledby="cta-heading">
					<h2 id="cta-heading">Ready to get on the water?</h2>
					<p>Tours depart daily from Split. Book early in July and August — popular routes fill 3–5 days ahead.</p>
					<div class="cta-band-btns">
						<a class="btn-primary" href="/tours">Browse all tours</a>
						<a class="btn-secondary" href="/contact?tour=create-perfect-day-private">Plan a private charter</a>
					</div>
				</section>
			</div>
		</div>
	</main>
</SiteLayout>

<style>
	.home-page .page-shell {
		padding: 0 var(--page-gutter);
	}

	.home-page .cta-band-btns .btn-primary,
	.home-page .cta-band-btns .btn-secondary {
		min-height: unset;
	}

	.dest-card {
		height: 110px;
		text-decoration: none;
		color: inherit;
	}

	.type-icon--group {
		color: var(--color-accent);
	}

	.type-icon--private {
		color: var(--color-category-private-icon);
	}

	.type-cta {
		display: inline-block;
		text-decoration: none;
		color: var(--color-text-primary);
	}

	.btn-primary--compact {
		font-size: 12px;
		padding: 6px 14px;
		min-height: unset;
	}

	.home-page .cards-scroll .tour-card.featured {
		border: 0.5px solid var(--color-border-tertiary);
	}

	.home-page .cards-scroll .tour-card.featured:hover {
		border-color: var(--color-border-primary);
	}
</style>
