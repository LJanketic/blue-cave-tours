---
export const prerender = true;

import NotFoundPanel from '../components/NotFoundPanel.astro';
import { pageTitle } from '../config/site';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title={pageTitle('Page not found')}>
	<main id="main">
		<NotFoundPanel title="404" description="That page doesn’t exist or the tour slug is wrong.">
			<a href="/tours">Browse all tours</a>
			{' or '}
			<a href="/">return home</a>.
		</NotFoundPanel>
	</main>
</SiteLayout>
