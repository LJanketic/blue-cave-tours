---
import SiteLayout from '../../layouts/SiteLayout.astro';

const demo = Astro.url.searchParams.has('demo');
const tourId = Astro.url.searchParams.get('tourId');
---

<SiteLayout
	title={demo ? 'Demo booking — Blue Cave Tours' : 'Booking confirmed — Blue Cave Tours'}
	description="Thank you for your booking or demo checkout."
>
	<main class="wrap" id="main">
		{demo && (
			<p class="banner" role="status">
				Demo checkout — no payment was processed{tourId ? ` (tour: ${tourId})` : ''}.
			</p>
		)}
		<h1>{demo ? 'Demo complete' : 'Thank you!'}</h1>
		<p class="lead">
			{demo
				? 'This run used mock checkout (no Stripe session).'
				: 'Your payment was processed with Stripe Checkout.'}
		</p>
		<p class="muted">
			We’ll follow up by email with meeting-point details and anything you still need for the day of your tour.
		</p>
		<p class="muted">
			If you need help, reach us at <a href="mailto:info@bluecavetours.com">info@bluecavetours.com</a> or{' '}
			<a href="tel:+385919888838">+385 91 988 88 38</a>.
		</p>
		<p>
			<a class="back" href="/tours">Browse tours</a> · <a class="back" href="/">Home</a>
		</p>
	</main>
</SiteLayout>

<style>
	.wrap {
		max-width: 560px;
		margin: 0 auto;
		padding: 4rem 1.25rem 5rem;
	}

	.banner {
		margin: 0 0 1.25rem;
		padding: 0.75rem 1rem;
		background: #fff7ed;
		border: 1px solid #fed7aa;
		border-radius: 8px;
		color: #9a3412;
		font-weight: 600;
		font-size: 0.9375rem;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		margin: 0 0 1rem;
		color: var(--color-nav);
	}

	.lead {
		font-size: 1.125rem;
		margin: 0 0 1rem;
	}

	.muted {
		color: var(--color-muted);
		margin: 0 0 1rem;
		line-height: 1.55;
	}

	.back {
		font-weight: 700;
		color: var(--color-nav-elevated);
	}
</style>
