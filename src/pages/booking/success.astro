---
export const prerender = false;

import { pageTitle, SITE_EMAIL, SITE_NAME, SITE_PHONE, SITE_PHONE_DISPLAY } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getTourBySlug } from '../../lib/tours';

const tourIdParam = Astro.url.searchParams.get('tourId');
const bookedTour = tourIdParam ? getTourBySlug(tourIdParam) : undefined;

if (tourIdParam && !bookedTour) {
	return Astro.redirect('/404');
}
---

<SiteLayout
	title={pageTitle('Booking confirmed')}
	description={`Your booking with ${SITE_NAME} has been received.`}
>
	<main class="status-page" id="main">
		<p class="status-banner status-banner--info" role="status">
			{bookedTour ? `Reserved: ${bookedTour.title}` : 'Your reservation has been received.'}
		</p>
		<h1>Thank you — booking received</h1>
		<p class="lead">
			We’ll confirm your date, meeting time, and any extras by email shortly. If you don’t hear from us within one
			business day, please reach out.
		</p>
		<p class="muted">
			Meet at Riva stand 14 unless we send other details. Questions? Email{' '}
			<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a> or call{' '}
			<a href={`tel:${SITE_PHONE}`}>{SITE_PHONE_DISPLAY}</a>.
		</p>
		<p>
			<a class="back" href="/tours">Browse tours</a> · <a class="back" href="/">Home</a>
		</p>
	</main>
</SiteLayout>
