---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Booking confirmed — Blue Cave Tours" description="Thank you — your payment was submitted through Stripe.">
	<main class="wrap" id="main">
		<h1>Thank you!</h1>
		<p class="lead">Your payment was processed with Stripe Checkout.</p>
		<p class="muted">
			We’ll follow up by email with meeting-point details and anything you still need for the day of your tour.
		</p>
		<p class="muted">
			If you need help, reach us at <a href="mailto:info@bluecavetours.com">info@bluecavetours.com</a> or{' '}
			<a href="tel:+385919888838">+385 91 988 88 38</a>.
		</p>
		<p><a class="back" href="/">Back to home</a></p>
	</main>
</BaseLayout>

<style>
	.wrap {
		max-width: 560px;
		margin: 0 auto;
		padding: 4rem 1.25rem 5rem;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		margin: 0 0 1rem;
		color: var(--color-nav);
	}

	.lead {
		font-size: 1.125rem;
		margin: 0 0 1rem;
	}

	.muted {
		color: var(--color-muted);
		margin: 0 0 1rem;
		line-height: 1.55;
	}

	.back {
		display: inline-flex;
		margin-top: 0.5rem;
		font-weight: 700;
		color: var(--color-nav-elevated);
	}
</style>
