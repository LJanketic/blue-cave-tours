---
import { pageTitle, SITE_EMAIL, SITE_PHONE, SITE_PHONE_TEL } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { t } from '../../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale ?? 'hr';
const tourId = Astro.url.searchParams.get('tourId');
const provider = Astro.url.searchParams.get('provider');
const orderId = Astro.url.searchParams.get('orderId') ?? Astro.url.searchParams.get('token');
const sessionId = Astro.url.searchParams.get('sessionId') ?? Astro.url.searchParams.get('session_id');
const hasPaymentRef = Boolean(orderId || sessionId);

const toursHref = getRelativeLocaleUrl(locale, '/tours');
const homeHref = getRelativeLocaleUrl(locale, '/');

const leadKey = !hasPaymentRef
	? 'bookingSuccess.unverifiedLead'
	: provider === 'teya'
		? 'bookingSuccess.leadTeya'
		: provider === 'paypal'
			? 'bookingSuccess.leadPayPal'
			: 'bookingSuccess.leadGeneric';
---

<SiteLayout
	title={pageTitle(t('bookingSuccess.title', locale))}
	description={t('bookingSuccess.description', locale)}
>
	<main
		class="wrap"
		id="main"
		data-booking-success
		data-verifying={t('bookingSuccess.verifying', locale)}
		data-lead-paypal={t('bookingSuccess.leadPayPal', locale)}
		data-lead-teya={t('bookingSuccess.leadTeya', locale)}
		data-lead-generic={t('bookingSuccess.leadGeneric', locale)}
		data-unverified={t('bookingSuccess.unverifiedLead', locale)}
		data-pending={t('bookingSuccess.pending', locale)}
		data-failed={t('bookingSuccess.failed', locale)}
		data-followup={t('bookingSuccess.followup', locale)}
	>
		<h1>{t('bookingSuccess.title', locale)}</h1>
		<p class="lead" data-booking-success-lead>{t(leadKey, locale)}</p>
		{tourId && (
			<p class="muted">
				{t('bookingSuccess.tour', locale)}: {tourId}
			</p>
		)}
		<p class="status" data-booking-success-status hidden role="status" aria-live="polite"></p>
		{hasPaymentRef && <p class="muted">{t('bookingSuccess.followup', locale)}</p>}
		<p class="muted">
			{t('bookingSuccess.help', locale)}{' '}
			<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a> ·{' '}
			<a href={`tel:${SITE_PHONE_TEL}`}>{SITE_PHONE}</a>.
		</p>
		<p>
			<a class="back" href={toursHref}>{t('bookingSuccess.browse', locale)}</a> ·{' '}
			<a class="back" href={homeHref}>{t('bookingSuccess.home', locale)}</a>
		</p>
	</main>
</SiteLayout>

<script>
	import { initBookingSuccess } from '../../client/booking-success';
	initBookingSuccess();
</script>

<style>
	.wrap {
		max-width: 560px;
		margin: 0 auto;
		padding: 4rem 1.25rem 5rem;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		margin: 0 0 1rem;
		color: var(--color-nav);
	}

	.lead {
		font-size: 1.125rem;
		margin: 0 0 1rem;
	}

	.muted {
		color: var(--color-muted);
		margin: 0 0 1rem;
		line-height: 1.55;
	}

	.status {
		margin: 0 0 1rem;
		font-size: 0.95rem;
		color: var(--color-nav-elevated);
	}

	.status[data-state='error'] {
		color: #b91c1c;
	}

	.back {
		font-weight: 700;
		color: var(--color-nav-elevated);
	}
</style>
