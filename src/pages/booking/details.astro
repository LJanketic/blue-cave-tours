---
export const prerender = true;

import { pageTitle } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
---

<SiteLayout
	title={pageTitle('Booking details')}
	description="What we collect when you book a boat tour from Split: party size, date, contact details, and pricing."
>
	<main id="main" class="page-shell">
		<h1 class="page-title">What we need to book your tour</h1>
		<p class="page-lead">
			Whether you book online or request a quote, here is the information we use to confirm your day on the water.
		</p>

		<section class="prose-section" aria-labelledby="f-heading">
			<h2 id="f-heading">Guest &amp; party</h2>
			<ul class="prose-list">
				<li>Number of guests (adults, children, infants) — group size affects pricing.</li>
				<li>Preferred date and any flexibility if your plans might shift.</li>
				<li>Contact details: name, email, phone, and language preference.</li>
			</ul>
		</section>

		<section class="prose-section" aria-labelledby="p-heading">
			<h2 id="p-heading">Price &amp; extras</h2>
			<ul class="prose-list">
				<li>Adult, child, and infant rates where applicable — shown per tour before you pay.</li>
				<li>Promotional or group discounts when offered for your date and route.</li>
				<li>Cave and park entry fees are often <strong>not</strong> included in the base price and are payable on-site.</li>
			</ul>
		</section>

		<section class="prose-section" aria-labelledby="o-heading">
			<h2 id="o-heading">Confirmation</h2>
			<ul class="prose-list">
				<li>Book now reserves your selection — we follow up by email or phone to confirm date, party size, and total.</li>
				<li>Private charters receive a tailored quote with everything included.</li>
				<li>Cave and park entry fees may still be payable on-site where applicable.</li>
			</ul>
		</section>

		<section class="prose-section" aria-labelledby="m-heading">
			<h2 id="m-heading">After you book</h2>
			<ul class="prose-list">
				<li>Meeting point on Split’s Riva (stand 14) and what to bring for the day.</li>
				<li>Confirmation by email with any updates before departure.</li>
			</ul>
		</section>

		<p>
			<a class="back" href="/contact">Contact us</a> · <a href="/tours">Browse tours</a>
		</p>
	</main>
</SiteLayout>

<style>
	.back {
		font-weight: var(--font-weight-bold);
		color: var(--color-nav-elevated);
	}
</style>
