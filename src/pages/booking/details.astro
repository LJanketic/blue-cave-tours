---
import { pageTitle } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { t } from '../../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale;
const contactHref = getRelativeLocaleUrl(locale, '/contact');
const toursHref = getRelativeLocaleUrl(locale, '/tours');
---

<SiteLayout
	title={pageTitle(t('bookingDetails.title', locale))}
	description={t('bookingDetails.description', locale)}
>
	<main id="main" class="main">
		<h1 class="title">{t('bookingDetails.title', locale)}</h1>
		<p class="lead">{t('bookingDetails.lead', locale)}</p>

		<section class="block" aria-labelledby="f-heading">
			<h2 id="f-heading" class="h2">{t('bookingDetails.guestHeading', locale)}</h2>
			<ul class="list">
				<li>{t('bookingDetails.guest1', locale)}</li>
				<li>{t('bookingDetails.guest2', locale)}</li>
				<li>{t('bookingDetails.guest3', locale)}</li>
			</ul>
		</section>

		<section class="block" aria-labelledby="p-heading">
			<h2 id="p-heading" class="h2">{t('bookingDetails.pricingHeading', locale)}</h2>
			<ul class="list">
				<li>{t('bookingDetails.pricing1', locale)}</li>
				<li>{t('bookingDetails.pricing2', locale)}</li>
				<li>{t('bookingDetails.pricing3', locale)}</li>
			</ul>
		</section>

		<section class="block" aria-labelledby="o-heading">
			<h2 id="o-heading" class="h2">{t('bookingDetails.paymentHeading', locale)}</h2>
			<ul class="list">
				<li>{t('bookingDetails.payment1', locale)}</li>
				<li>{t('bookingDetails.payment2', locale)}</li>
				<li>{t('bookingDetails.payment3', locale)}</li>
			</ul>
		</section>

		<section class="block" aria-labelledby="m-heading">
			<h2 id="m-heading" class="h2">{t('bookingDetails.afterHeading', locale)}</h2>
			<ul class="list">
				<li>{t('bookingDetails.after1', locale)}</li>
				<li>{t('bookingDetails.after2', locale)}</li>
			</ul>
		</section>

		<p>
			<a class="cta" href={contactHref}>{t('bookingDetails.contact', locale)}</a> ·{' '}
			<a href={toursHref}>{t('bookingDetails.browse', locale)}</a>
		</p>
	</main>
</SiteLayout>

<style>
	.main {
		max-width: 720px;
		margin: 0 auto;
		padding: 2.5rem 1.25rem 4rem;
	}

	.title {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		color: var(--color-nav);
		margin: 0 0 0.75rem;
	}

	.lead {
		margin: 0 0 2rem;
		line-height: 1.65;
		color: var(--color-muted);
	}

	.block {
		margin-bottom: 1.75rem;
	}

	.h2 {
		font-size: 1.125rem;
		margin: 0 0 0.5rem;
		color: var(--color-nav);
	}

	.list {
		margin: 0;
		padding-left: 1.25rem;
		color: var(--color-muted);
		line-height: 1.6;
	}

	code {
		font-size: 0.9em;
		background: #f1f5f9;
		padding: 0.1em 0.35em;
		border-radius: 4px;
	}

	.cta {
		font-weight: 700;
	}
</style>
