---
import { pageTitle, SITE_EMAIL, SITE_PHONE, SITE_PHONE_TEL } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { t } from '../../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale;
const toursHref = getRelativeLocaleUrl(locale, '/tours');
const homeHref = getRelativeLocaleUrl(locale, '/');
---

<SiteLayout title={pageTitle(t('bookingCancel.title', locale))} description={t('bookingCancel.description', locale)}>
	<main class="wrap" id="main">
		<h1>{t('bookingCancel.title', locale)}</h1>
		<p class="lead">{t('bookingCancel.lead', locale)}</p>
		<p class="muted">
			{t('bookingCancel.help', locale)} <a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a> ·{' '}
			<a href={`tel:${SITE_PHONE_TEL}`}>{SITE_PHONE}</a>.
		</p>
		<p>
			<a class="back" href={toursHref}>{t('bookingSuccess.browse', locale)}</a> ·{' '}
			<a class="back" href={homeHref}>{t('bookingSuccess.home', locale)}</a>
		</p>
	</main>
</SiteLayout>

<style>
	.wrap {
		max-width: 560px;
		margin: 0 auto;
		padding: 4rem 1.25rem 5rem;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		margin: 0 0 1rem;
		color: var(--color-nav);
	}

	.lead {
		font-size: 1.125rem;
		margin: 0 0 1rem;
	}

	.muted {
		color: var(--color-muted);
		margin: 0 0 1rem;
		line-height: 1.55;
	}

	.back {
		font-weight: 700;
		color: var(--color-nav-elevated);
	}
</style>
