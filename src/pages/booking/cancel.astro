---
import SiteLayout from '../../layouts/SiteLayout.astro';
---

<SiteLayout title="Checkout cancelled — Blue Cave Tours" description="You left the Stripe checkout before completing payment.">
	<main class="wrap" id="main">
		<h1>Checkout cancelled</h1>
		<p class="lead">No charge was made. You can return anytime and pick up where you left off.</p>
		<p class="muted">
			Questions? Email <a href="mailto:info@bluecavetours.com">info@bluecavetours.com</a> or call{' '}
			<a href="tel:+385919888838">+385 91 988 88 38</a>.
		</p>
		<p>
			<a class="back" href="/tours">Browse tours</a> · <a class="back" href="/">Home</a>
		</p>
	</main>
</SiteLayout>

<style>
	.wrap {
		max-width: 560px;
		margin: 0 auto;
		padding: 4rem 1.25rem 5rem;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		margin: 0 0 1rem;
		color: var(--color-nav);
	}

	.lead {
		font-size: 1.125rem;
		margin: 0 0 1rem;
	}

	.muted {
		color: var(--color-muted);
		margin: 0 0 1rem;
		line-height: 1.55;
	}

	.back {
		font-weight: 700;
		color: var(--color-nav-elevated);
	}
</style>
