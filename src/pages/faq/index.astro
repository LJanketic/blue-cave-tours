---
export const prerender = true;

import { pageTitle, SITE_EMAIL, SITE_PHONE, SITE_PHONE_DISPLAY } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import FAQPage from '../../components/vue/FAQPage.vue';
import { FAQ_ITEMS } from '../../data/faq';
import { faqPageJsonLd } from '../../lib/seo';

const jsonLd = faqPageJsonLd(FAQ_ITEMS);
---

<SiteLayout
	title={pageTitle('FAQ')}
	description="Frequently asked questions about boat tours from Split, Blue Cave visits, weather, and safety."
	jsonLd={jsonLd}
>
	<main id="main" class="page-shell">
		<FAQPage
			client:visible
			siteEmail={SITE_EMAIL}
			sitePhone={SITE_PHONE}
			sitePhoneDisplay={SITE_PHONE_DISPLAY}
		/>
	</main>
</SiteLayout>

<style>
	.page-shell :global(.faq-page) {
		padding: 0 0 2rem;
		font-size: 14px;
		color: var(--color-text-primary);
	}
</style>
