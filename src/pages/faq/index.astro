---
export const prerender = true;

import { pageTitle } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { FAQ_ITEMS } from '../../data/faq';
---

<SiteLayout
	title={pageTitle('FAQ')}
	description="Frequently asked questions about boat tours from Split, Blue Cave visits, weather, and safety."
>
	<main id="main" class="page-shell">
		<h1 class="page-title">Frequently asked questions</h1>
		<p class="page-lead">
			Answers to the questions guests ask most often before booking. For anything else, <a href="/contact">contact us</a>.
		</p>

		<section class="prose-section" aria-labelledby="g-heading">
			<h2 id="g-heading">General</h2>
			<dl class="faq">
				{
					FAQ_ITEMS.map((item) => (
						<div class="faq__row">
							<dt>{item.question}</dt>
							<dd>
								{item.link ? (
									<>
										{item.answer}{' '}
										<a href={item.link.href}>{item.link.label}</a>.
									</>
								) : (
									item.answer
								)}
							</dd>
						</div>
					))
				}
			</dl>
		</section>

		<section class="prose-section faq-partner" aria-labelledby="s-heading">
			<h2 id="s-heading">Partner &amp; voucher bookings</h2>
			<p class="page-meta">
				If you booked through a partner or voucher platform, cancellation terms and changes may follow their policy.
				Contact us with your reference and we’ll help.
			</p>
		</section>
	</main>
</SiteLayout>

<style>
	dt {
		margin: 0 0 0.35rem;
		font-family: var(--font-display);
		font-size: var(--text-base);
		font-weight: var(--font-weight-medium);
		color: var(--color-nav);
	}

	dd {
		margin: 0;
		font-size: var(--text-sm);
		color: var(--color-muted);
		line-height: 1.55;
	}

	.faq__row {
		padding: 1rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	.faq__row:first-of-type {
		border-top: 1px solid var(--color-border);
	}

	.faq-partner {
		padding: 1.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
	}

	.faq-partner .page-meta {
		margin-bottom: 0;
	}
</style>
