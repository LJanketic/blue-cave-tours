---
export const prerender = true;

import { pageTitle } from '../../../config/site';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import GroupBookingFlow from '../../../components/vue/GroupBookingFlow.vue';
import { getAllTours } from '../../../lib/tours';
import { supportsInstantBook } from '../../../lib/booking';
import type { TourDetail } from '../../../types/tour';

export function getStaticPaths() {
	return getAllTours()
		.filter((tour) => supportsInstantBook(tour))
		.map((tour) => ({
			params: { slug: tour.slug },
			props: { tour },
		}));
}

type Props = { tour: TourDetail };
const { tour } = Astro.props;

const standMatch = tour.meetingPoint.match(/stand number (\d+)/i);
const meetingShort = standMatch
	? `Riva stand ${standMatch[1]}`
	: (tour.meetingPoint.replace(/^Meet at /i, '').split('.')[0]?.trim() ?? tour.meetingPoint);
---

<SiteLayout title={pageTitle(`Book — ${tour.title}`)} description={`Book ${tour.title} — choose date, guests, and contact details.`} booking robots="noindex, nofollow">
	<main id="main" class="page-shell page-shell--narrow">
		<div class="page group-booking-page">
			<div class="step-bar" aria-label="Booking progress">
				<div class="step done">
					<div class="step-dot"><i class="ti ti-check" aria-hidden="true"></i></div>
					<span class="step-lbl">Tour type</span>
				</div>
				<div class="step-line"></div>
				<div class="step active">
					<div class="step-dot">2</div>
					<span class="step-lbl">Date &amp; guests</span>
				</div>
				<div class="step-line"></div>
				<div class="step next">
					<div class="step-dot">3</div>
					<span class="step-lbl">Review</span>
				</div>
				<div class="step-line"></div>
				<div class="step next">
					<div class="step-dot">4</div>
					<span class="step-lbl">Payment</span>
				</div>
			</div>

			<div class="tour-snap">
				<div class="snap-img" aria-hidden="true">
					<i class="ti ti-sunset"></i>
				</div>
				<div>
					<p class="snap-name">{tour.title}</p>
					<div class="snap-meta">
						<span class="snap-tag">
							<i class="ti ti-clock" aria-hidden="true"></i>
							{tour.duration}
						</span>
						<span class="snap-tag snap-tag--location" title={tour.meetingPoint}>
							<i class="ti ti-map-pin" aria-hidden="true"></i>
							{meetingShort}
						</span>
					</div>
				</div>
			</div>

			<GroupBookingFlow
				client:load
				tourSlug={tour.slug}
				tourTitle={tour.title}
				duration={tour.duration}
				departure={tour.departure}
				fromPrice={tour.fromPrice}
				priceNotes={tour.priceNotes}
			/>
		</div>
	</main>
</SiteLayout>

<style>
	.group-booking-page {
		max-width: 560px;
		margin: 0 auto;
		padding: 1.5rem 0 2rem;
		font-size: 14px;
	}

	.group-booking-page .step-bar {
		display: flex;
		align-items: center;
		margin-bottom: 28px;
	}

	.group-booking-page .step {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
	}

	.group-booking-page .step-dot {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 11px;
		font-weight: 500;
		flex-shrink: 0;
	}

	.group-booking-page .step.done .step-dot {
		background: var(--color-background-success);
		color: var(--color-text-success);
	}

	.group-booking-page .step.done .step-lbl {
		color: var(--color-text-secondary);
	}

	.group-booking-page .step.active .step-dot {
		background: var(--color-text-primary);
		color: var(--color-background-primary);
	}

	.group-booking-page .step.active .step-lbl {
		color: var(--color-text-primary);
		font-weight: 500;
	}

	.group-booking-page .step.next .step-dot {
		background: var(--color-background-secondary);
		color: var(--color-text-tertiary);
		border: 0.5px solid var(--color-border-secondary);
	}

	.group-booking-page .step.next .step-lbl {
		color: var(--color-text-tertiary);
	}

	.group-booking-page .step-line {
		flex: 1;
		height: 0.5px;
		background: var(--color-border-secondary);
		margin: 0 8px;
	}

	.group-booking-page .step-dot .ti {
		font-size: 11px;
	}

	.group-booking-page .snap-img .ti {
		font-size: 22px;
		color: var(--color-border-secondary);
	}

	.group-booking-page .snap-meta {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}

	.group-booking-page .tour-snap {
		display: flex;
		gap: 12px;
		align-items: center;
		background: var(--color-background-secondary);
		border-radius: var(--radius-lg);
		padding: 12px 14px;
		margin-bottom: 20px;
	}

	.group-booking-page .snap-img {
		width: 56px;
		height: 56px;
		border-radius: var(--radius-md);
		background: var(--color-background-primary);
		border: 0.5px solid var(--color-border-tertiary);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.group-booking-page .snap-name {
		font-size: 14px;
		font-weight: 500;
		margin: 0 0 3px;
	}

	.group-booking-page .snap-tag {
		font-size: 12px;
		color: var(--color-text-secondary);
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.group-booking-page .snap-tag--location {
		max-width: 180px;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
</style>
