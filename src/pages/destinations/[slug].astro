---
export const prerender = true;

import { pageTitle } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import ImageGallery from '../../components/vue/ImageGallery.vue';
import TourImage from '../../components/TourImage.astro';
import {
	bestTimeBarStyle,
	getAllDestinations,
	getDestinationPhoto,
	getToursForDestination,
	MONTH_LABELS,
} from '../../lib/destinations';
import { supportsInstantBook } from '../../lib/booking';
import { PHOTO, galleryFrom } from '../../data/tour-photos';

export function getStaticPaths() {
	return getAllDestinations().map((destination) => ({
		params: { slug: destination.slug },
		props: { destination },
	}));
}

type Props = { destination: import('../../data/destinations').Destination };

const TAG_ICONS: Record<string, string> = {
	Swimming: 'swimming',
	Island: 'building-lighthouse',
	Cave: 'droplet',
	Culture: 'building-castle',
	'Half-day': 'clock',
	Snorkelling: 'mask',
	Departure: 'anchor',
	'Historic city': 'building',
	'Riva harbour': 'map-pin',
	'Must-see': 'star',
	'Hidden bays': 'beach',
};

const HIGHLIGHT_ICONS = ['droplet', 'building-fortress', 'leaf', 'glass-full', 'beach', 'moon-stars'];

function tagIcon(tag: string): string {
	return TAG_ICONS[tag] ?? 'star';
}

function nearbyTourCount(slug: string): number {
	return getToursForDestination(slug).length;
}

const { destination } = Astro.props;
const tours = getToursForDestination(destination.slug);
const heroPhoto = getDestinationPhoto(destination);
const galleryPhotos = galleryFrom(heroPhoto, PHOTO.blueLagoon, PHOTO.hvar, PHOTO.pakleni).map(
	(photo, index) => ({
		color: photo.color,
		alt: photo.alt,
		icon: index === 0 ? destination.icon : ['anchor', 'swimming', 'building-lighthouse', 'sunset'][index % 4],
	}),
);

type HeroTag = { icon: string; label: string; variant: 'feat' | 'group' | 'private' | 'tip' };
const heroTags: HeroTag[] = [
	...destination.tags.map((tag): HeroTag => ({ icon: tagIcon(tag), label: tag, variant: 'feat' })),
	...(destination.tipTag
		? [{ icon: destination.tipTag.icon, label: destination.tipTag.label, variant: 'tip' } as HeroTag]
		: []),
];

const mapUrl =
	'https://www.google.com/maps/search/?api=1&query=Riva+promenade+Split+Croatia+stand+14';
const bestSeason = destination.bestTimeMonths.some((s, i) => s >= 2 && i >= 4 && i <= 9)
	? 'May – Oct'
	: 'Jun – Sep';
const visitLabel = destination.name.replace(/\s+island$/i, '').split('(')[0].trim();
const distanceGeo = destination.geo.find((g) => /distance/i.test(g.label));
const travelGeo = destination.geo.find((g) => /travel time/i.test(g.label)) ?? destination.geo[1];
const fromLabel = distanceGeo
	? distanceGeo.label.replace(/^Distance from\s+/i, 'From ')
	: 'From Split';
const mapStubLabel = distanceGeo
	? `View on map — ${distanceGeo.value}`
	: 'View on map — depart from Split Riva';
---

<SiteLayout
	title={pageTitle(destination.name)}
	description={destination.shortDescription}
>
	<main id="main" class="page-shell dest-detail-page">
		<article class="page">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/destinations">Destinations</a>
				<span aria-hidden="true"> › </span>
				<span aria-current="page">{destination.name}</span>
			</nav>

			<ImageGallery
				client:visible
				hero={galleryPhotos[0]}
				gallery={galleryPhotos.slice(1)}
				tags={heroTags}
			/>

			<div class="layout">
				<div>
					<h1 class="dest-title">{destination.name}</h1>
					<p class="intro-text dest-intro">{destination.intro}</p>

					<section class="section" aria-labelledby="highlights-heading">
						<h2 id="highlights-heading" class="sec-title">Highlights</h2>
						<div class="highlights">
							{
								destination.highlights.map((hl, index) => (
									<div class="hl-item">
										<i
											class={`ti ti-${HIGHLIGHT_ICONS[index % HIGHLIGHT_ICONS.length]}`}
											aria-hidden="true"
										></i>
										{hl}
									</div>
								))
							}
						</div>
						<div class="highlights-marquee" aria-hidden="true">
							<div class="marquee-track">
								{
									[...destination.highlights, ...destination.highlights].map((hl, index) => {
										const originalIndex = index % destination.highlights.length;
										return (
											<div class="hl-item">
												<i
													class={`ti ti-${HIGHLIGHT_ICONS[originalIndex % HIGHLIGHT_ICONS.length]}`}
													aria-hidden="true"
												></i>
												{hl}
											</div>
										);
									})
								}
							</div>
						</div>
					</section>

					<section class="section" aria-labelledby="best-time-heading">
						<h2 id="best-time-heading" class="sec-title">Best time to visit</h2>
						<div class="best-time-grid" role="img" aria-label="Seasonality chart by month">
							{
								destination.bestTimeMonths.map((score, index) => {
									const bar = bestTimeBarStyle(score);
									return (
										<div class="month-col">
											<div class="month-bar-wrap">
												<div
													class="month-bar"
													style={`height: ${bar.height}; background: ${bar.background}`}
												></div>
											</div>
											<span class="month-lbl">{MONTH_LABELS[index]}</span>
										</div>
									);
								})
							}
						</div>
						<div class="month-note">
							<span>
								<span class="legend-dot legend-dot--peak"></span>
								Peak season
							</span>
							<span>
								<span class="legend-dot legend-dot--good"></span>
								Good
							</span>
							<span>
								<span class="legend-dot legend-dot--off"></span>
								Off season
							</span>
						</div>
						<p class="best-time-note">{destination.bestTimeNote}</p>
					</section>

					<section class="section" aria-labelledby="location-heading">
						<h2 id="location-heading" class="sec-title">Location &amp; getting there</h2>
						<a class="map-stub" href={mapUrl} target="_blank" rel="noopener noreferrer">
							<i class="ti ti-map-2" aria-hidden="true"></i>
							{mapStubLabel}
						</a>
						<div class="info-grid">
							{
								destination.geo.map((fact) => (
									<div class="info-item">
										<span class="info-label">{fact.label}</span>
										<span class="info-val">{fact.value}</span>
									</div>
								))
							}
						</div>
					</section>

					<section class="section" aria-labelledby="nearby-heading">
						<h2 id="nearby-heading" class="sec-title">Also nearby</h2>
						{
							destination.nearby.map((stop) => (
								<a class="nearby-item" href={`/destinations/${stop.slug}`}>
									<i class={`ti ti-${stop.icon}`} aria-hidden="true"></i>
									{stop.name}
									<span class="nearby-dist">{stop.distance}</span>
								</a>
							))
						}
					</section>

					<section class="section" aria-labelledby="tips-heading">
						<h2 id="tips-heading" class="sec-title">Insider tips</h2>
						{
							destination.insiderTips.map((tip, index) => (
								<div class="insider-item">
									<span class="insider-num">{index + 1}</span>
									<span class="insider-text">{tip}</span>
								</div>
							))
						}
					</section>

					<section class="section" aria-labelledby="tours-heading">
						<h2 id="tours-heading" class="sec-title">
							Tours that visit {visitLabel}
							<span class="tours-count">({tours.length})</span>
						</h2>
						{
							tours.map((tour) => {
								const instant = supportsInstantBook(tour);
								return (
									<a class="tour-link-card" href={`/tours/${tour.slug}`}>
										<div class="tc-head">
											<div class="tc-thumb">
												<TourImage photo={tour.image} layout="thumb" icon="sailboat" />
											</div>
											<div>
												<h3 class="tc-name">{tour.title}</h3>
												<div class="tc-meta">
													<span class="tc-tag">
														<i class="ti ti-clock" aria-hidden="true"></i>
														{tour.duration}
													</span>
													<span class="tc-tag">
														<i class={`ti ti-${instant ? 'users' : 'crown'}`} aria-hidden="true"></i>
														{instant ? 'Group' : 'Private'}
													</span>
													<span class="tc-tag">
														<i class="ti ti-map-pin" aria-hidden="true"></i>
														Stops at {visitLabel}
													</span>
													{
														tour.featured && (
															<span class="tc-tag tc-tag--featured">
																<i class="ti ti-star" aria-hidden="true"></i>
																Best seller
															</span>
														)
													}
												</div>
											</div>
										</div>
										<div class="tc-foot">
											<div>
												<span class="tc-from">From </span>
												<span class="tc-price">{tour.fromPrice}</span>
												<span class="tc-per"> / person</span>
											</div>
											<span class="tc-cta">View tour</span>
										</div>
									</a>
								);
							})
						}
					</section>
				</div>

				<aside class="sticky-card" aria-label="Destination summary">
					<p class="sidebar-title">{destination.name} at a glance</p>
					<div class="sc-stat">
						<span class="sc-stat-label">Tours visiting</span>
						<span class="sc-stat-val">
							{tours.length} tour{tours.length === 1 ? '' : 's'}
						</span>
					</div>
					<div class="sc-stat">
						<span class="sc-stat-label">Best season</span>
						<span class="sc-stat-val">{bestSeason}</span>
					</div>
					{
						travelGeo && (
							<div class="sc-stat">
								<span class="sc-stat-label">{fromLabel}</span>
								<span class="sc-stat-val">{travelGeo.value}</span>
							</div>
						)
					}
					<hr class="sc-divider" />
					<p class="conditions-label">Current conditions</p>
					<div class="conditions-row">
						<span class="conditions-weather">
							<i class="ti ti-sun" aria-hidden="true"></i>
							Check forecast
						</span>
						<span class="conditions-temp">—</span>
					</div>
					<p class="conditions-note">Sea temp varies · Light winds typical in season</p>
					<hr class="sc-divider" />
					<a class="cta-primary" href={`/tours?destination=${destination.slug}`}>
						<i class="ti ti-sailboat" aria-hidden="true"></i>
						Browse {visitLabel} tours
					</a>
					<a class="cta-secondary" href="/contact?tour=create-perfect-day-private">
						<i class="ti ti-crown" aria-hidden="true"></i>
						Plan a private charter
					</a>
					<div class="sidebar-nearby-block">
						<hr class="sc-divider" />
						<p class="sidebar-nearby-label">Also nearby</p>
						<div class="sidebar-nearby-list">
							{
								destination.nearby.slice(0, 3).map((stop) => {
									const count = nearbyTourCount(stop.slug);
									return (
										<a class="sidebar-link" href={`/destinations/${stop.slug}`}>
											<span>{stop.name}</span>
											<span>
												{count} tour{count === 1 ? '' : 's'} →
											</span>
										</a>
									);
								})
							}
						</div>
					</div>
				</aside>
			</div>
		</article>
	</main>
</SiteLayout>

<style>
	.dest-detail-page .page {
		padding: 0 0 2rem;
		font-size: 14px;
	}

	.dest-detail-page .layout {
		grid-template-columns: 1fr 260px;
	}

	.dest-detail-page .dest-title {
		font-size: 21px;
		font-weight: 500;
		margin: 0 0 8px;
	}

	.dest-detail-page .dest-intro {
		margin: 0 0 20px;
		line-height: 1.75;
	}

	.dest-detail-page .section {
		margin-bottom: 24px;
	}

	.dest-detail-page .hl-item {
		padding: 9px 11px;
		line-height: 1.4;
	}

	.dest-detail-page .hl-item .ti {
		color: var(--color-accent);
	}

	.dest-detail-page .highlights-marquee {
		display: none;
		overflow: hidden;
		-webkit-mask-image: linear-gradient(
			to right,
			transparent,
			#000 24px,
			#000 calc(100% - 24px),
			transparent
		);
		mask-image: linear-gradient(
			to right,
			transparent,
			#000 24px,
			#000 calc(100% - 24px),
			transparent
		);
	}

	.dest-detail-page .marquee-track {
		display: flex;
		gap: 8px;
		width: max-content;
		animation: dest-highlights-marquee 26s linear infinite;
	}

	.dest-detail-page .marquee-track .hl-item {
		flex: 0 0 220px;
		white-space: normal;
	}

	.dest-detail-page .highlights-marquee:active .marquee-track {
		animation-play-state: paused;
	}

	@keyframes dest-highlights-marquee {
		from {
			transform: translateX(0);
		}

		to {
			transform: translateX(-50%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.dest-detail-page .marquee-track {
			animation: none;
		}
	}

	.dest-detail-page .best-time-note {
		font-size: 12px;
		color: var(--color-text-secondary);
		margin: 10px 0 0;
		line-height: 1.6;
	}

	.dest-detail-page .legend-dot--peak {
		background: var(--color-accent);
	}

	.dest-detail-page .map-stub .ti {
		color: var(--color-accent);
	}

	.dest-detail-page .tc-name {
		margin: 0 0 3px;
	}

	.dest-detail-page .conditions-label {
		font-size: 12px;
		font-weight: 500;
		margin: 0 0 6px;
		color: var(--color-text-secondary);
	}

	.dest-detail-page .conditions-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 13px;
	}

	.dest-detail-page .conditions-weather {
		color: var(--color-text-secondary);
	}

	.dest-detail-page .conditions-weather .ti {
		font-size: 14px;
		vertical-align: -2px;
		color: var(--color-text-warning);
		margin-right: 2px;
	}

	.dest-detail-page .conditions-temp {
		font-weight: 500;
	}

	.dest-detail-page .conditions-note {
		font-size: 11px;
		color: var(--color-text-tertiary);
		margin: 0 0 12px;
	}

	.dest-detail-page .legend-dot--good {
		background: #9fe1cb;
	}

	.dest-detail-page .legend-dot--off {
		background: var(--color-border-tertiary);
	}

	.dest-detail-page .tours-count {
		font-weight: 400;
		color: var(--color-text-tertiary);
		font-size: 13px;
	}

	.dest-detail-page .tc-meta {
		margin-bottom: 0;
	}

	.dest-detail-page .tc-tag--featured .ti {
		color: var(--color-text-warning);
	}

	.dest-detail-page .tc-foot {
		align-items: center;
	}

	.dest-detail-page .tc-price {
		font-size: 13px;
	}

	.dest-detail-page .tc-per {
		font-size: 11px;
		color: var(--color-text-tertiary);
	}

	.dest-detail-page .tc-cta {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
	}

	.dest-detail-page .sticky-card {
		padding: 1.1rem 1.25rem;
	}

	.dest-detail-page .sidebar-title {
		font-size: 13px;
		font-weight: 500;
		margin: 0 0 12px;
	}

	.dest-detail-page .sidebar-nearby-label {
		font-size: 12px;
		font-weight: 500;
		margin: 0 0 8px;
		color: var(--color-text-secondary);
	}

	.dest-detail-page .sidebar-nearby-list {
		display: flex;
		flex-direction: column;
		gap: 5px;
	}

	.dest-detail-page .cta-primary {
		padding: 11px;
		font-size: 13px;
		min-height: unset;
		margin-top: 0;
		text-decoration: none;
	}

	.dest-detail-page .cta-secondary {
		padding: 9px;
		min-height: unset;
	}

	.dest-detail-page :global(.img-hero) {
		height: 240px;
	}

	.dest-detail-page :global(.image-gallery__hero-icon) {
		font-size: 56px;
	}

	.dest-detail-page :global(.img-thumb) {
		height: 58px;
	}

	.dest-detail-page :global(.image-gallery__counter) {
		top: auto;
		bottom: 10px;
	}

	.dest-detail-page .tc-thumb :global(.placeholder-image) {
		width: 44px;
		height: 44px;
		min-height: 44px;
		border-radius: var(--radius-md);
	}

	.dest-detail-page .tc-thumb :global(.placeholder-image .ti) {
		font-size: 20px;
	}

	@media (max-width: 768px) {
		.dest-detail-page .layout {
			grid-template-columns: 1fr;
		}

		.dest-detail-page .sidebar-nearby-block {
			display: none;
		}

		.dest-detail-page .info-grid {
			grid-template-columns: 1fr;
		}

		.dest-detail-page .highlights {
			display: none;
		}

		.dest-detail-page .highlights-marquee {
			display: block;
		}

		.dest-detail-page .best-time-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	@media (max-width: 480px) {
		.dest-detail-page .best-time-grid {
			grid-template-columns: repeat(3, 1fr);
		}

		.dest-detail-page .tc-foot {
			flex-wrap: wrap;
			gap: 8px;
		}

		.dest-detail-page .tc-cta {
			margin-left: auto;
		}
	}
</style>
