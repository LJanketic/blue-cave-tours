---
export const prerender = true;

import { getImage } from 'astro:assets';
import NotFoundPanel from '../../components/NotFoundPanel.astro';
import TourDetailView from '../../components/tour/TourDetailView.astro';
import { pageTitle } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getAllTours, getTourBySlug } from '../../lib/tours';

export function getStaticPaths() {
	return getAllTours().map((tour) => ({ params: { slug: tour.slug } }));
}

const { slug } = Astro.params;
const tour = slug ? getTourBySlug(slug) : undefined;

if (!tour) {
	Astro.response.status = 404;
}

const ogImage = tour
	? await getImage({
			src: tour.image.src,
			width: 1200,
			height: 630,
			fit: 'cover',
			format: 'jpg',
		})
	: undefined;
---

<SiteLayout
	title={tour ? pageTitle(tour.title) : pageTitle('Tour not found')}
	description={tour?.shortDescription ?? 'The requested tour does not exist.'}
	booking={Boolean(tour)}
	ogImage={ogImage?.src}
>
	<main id="main">
		{
			tour ? (
				<TourDetailView tour={tour} />
			) : (
				<NotFoundPanel
					title="Tour not found"
					description="The requested tour does not exist or the link may be outdated."
				>
					<a href="/tours">View all tours</a>
					{' · '}
					<a href="/">Home</a>
				</NotFoundPanel>
			)
		}
	</main>
</SiteLayout>
