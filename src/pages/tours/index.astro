---
import { pageTitle } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import TourCard from '../../components/TourCard.astro';
import TourCarousel from '../../components/TourCarousel.astro';
import { getAllTours } from '../../lib/tours';

const all = getAllTours();
---

<SiteLayout
	title={pageTitle('All tours')}
	description="Full catalog of boat tours and private days from Split: Blue Cave, islands, Blue Lagoon half-days, and custom private charters."
>
	<main id="main" class="page-shell page-shell--wide">
		<header class="page-head">
			<h1 class="page-title">All tours</h1>
			<p class="page-lead">
				Full catalog of boat tours and private charters from Split — Blue Cave, islands, lagoon half-days, and custom days
				at sea.
			</p>
		</header>
		<TourCarousel ariaLabel="All tours">
			{
				all.map((tour) => (
					<li class="tour-carousel__slide">
						<TourCard tour={tour} />
					</li>
				))
			}
		</TourCarousel>
	</main>
</SiteLayout>

<style>
	.page-head {
		margin-bottom: 2rem;
		max-width: 62ch;
	}
</style>
