---
export const prerender = true;

import { pageTitle } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import ToursCatalog from '../../components/vue/ToursCatalog.vue';
import { getAllDestinations } from '../../lib/destinations';
import { getAllTours } from '../../lib/tours';

const all = getAllTours();
const toursByDestination = Object.fromEntries(
	getAllDestinations().map((destination) => [destination.slug, destination.tourSlugs]),
);
---

<SiteLayout
	title={pageTitle('Our tours')}
	description="Full catalog of boat tours and private charters from Split — Blue Cave, islands, lagoon half-days, and custom days at sea."
	booking
>
	<main id="main" class="page-shell">
		<div class="page tours-page">
			<ToursCatalog client:visible tours={all} toursByDestination={toursByDestination} />
		</div>
	</main>
</SiteLayout>

<style>
	.tours-page {
		padding: 1.5rem 0 2rem;
		font-size: 14px;
	}

	@media (max-width: 768px) {
		.tours-page {
			padding-top: 1rem;
		}
	}
</style>
