---
export const prerender = true;

import {
	pageTitle,
	SITE_EMAIL,
	SITE_NAME,
	SITE_PHONE,
	SITE_PHONE_DISPLAY,
} from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getAllTours } from '../../lib/tours';

const tours = getAllTours();
const tourFromQuery = Astro.url.searchParams.get('tour') ?? '';
const selectedTour = tours.some((t) => t.slug === tourFromQuery) ? tourFromQuery : '';
const mapUrl =
	'https://www.google.com/maps/search/?api=1&query=Riva+promenade+Split+Croatia+stand+14';
const whatsappUrl = `https://wa.me/${SITE_PHONE.replace(/\D/g, '')}`;
---

<SiteLayout
	title={pageTitle('Contact')}
	description={`Reach ${SITE_NAME} on Split’s Riva — stand 14 — or send a message about tours and private charters.`}
>
	<main id="main" class="page-shell">
		<div class="page contact-page">
			<h1 class="contact-title">Contact us</h1>
			<p class="hero-sub">
				Questions, special requests, or just not sure which tour is right for you — get in touch. We usually
				reply within a couple of hours during the season.
			</p>

			<div class="contact-grid">
				<a class="contact-card" href={`tel:${SITE_PHONE}`}>
					<div class="cc-icon cc-icon--success">
						<i class="ti ti-phone" aria-hidden="true"></i>
					</div>
					<span class="cc-type">Phone</span>
					<span class="cc-value">{SITE_PHONE_DISPLAY}</span>
					<span class="cc-sub">Office line — Mon to Sun, 08:00–20:00 during season</span>
				</a>
				<a class="contact-card" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
					<div class="cc-icon cc-icon--success">
						<i class="ti ti-brand-whatsapp" aria-hidden="true"></i>
					</div>
					<span class="cc-type">WhatsApp</span>
					<span class="cc-value">{SITE_PHONE_DISPLAY}</span>
					<span class="cc-sub">Fastest response — typically within the hour</span>
				</a>
				<a class="contact-card" href={`mailto:${SITE_EMAIL}`}>
					<div class="cc-icon cc-icon--info">
						<i class="ti ti-mail" aria-hidden="true"></i>
					</div>
					<span class="cc-type">Email</span>
					<span class="cc-value">{SITE_EMAIL}</span>
					<span class="cc-sub">For bookings, invoices, and detailed requests</span>
				</a>
				<a class="contact-card" href={mapUrl} target="_blank" rel="noopener noreferrer">
					<div class="cc-icon cc-icon--location">
						<i class="ti ti-map-pin" aria-hidden="true"></i>
					</div>
					<span class="cc-type">Find us</span>
					<span class="cc-value">Riva promenade, stand 14</span>
					<span class="cc-sub">Split waterfront — meet before every departure</span>
				</a>
			</div>

			<div class="hours-card">
				<div class="hours-col">
					<p class="hours-label">Response hours</p>
					<div class="open-badge">
						<span class="open-dot" aria-hidden="true"></span>
						Open now
					</div>
					<div class="hours-row">
						<span class="hours-day">Mon – Fri</span>
						<span class="hours-time">08:00 – 20:00</span>
					</div>
					<div class="hours-row">
						<span class="hours-day">Sat – Sun</span>
						<span class="hours-time">08:00 – 18:00</span>
					</div>
				</div>
				<div class="hours-col">
					<p class="hours-label">Season</p>
					<div class="hours-row">
						<span class="hours-day">Apr – Nov</span>
						<span class="hours-time">Daily departures</span>
					</div>
					<div class="hours-row">
						<span class="hours-day">Off-season</span>
						<span class="hours-time">Email only</span>
					</div>
					<p class="hours-note">
						Private charters available year-round by request, weather permitting.
					</p>
				</div>
			</div>

			<div class="form-card">
				<p class="form-title">Send us a message</p>
				<form id="contact-form" novalidate>
					<input type="hidden" name="_startedAt" id="contact-started-at" value="" />
					<div class="form-field form-field--hp" aria-hidden="true">
						<label for="company">Company</label>
						<input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
					</div>
					<div class="form-grid">
						<div class="form-field form-field--name">
							<label for="name">Name <span class="sr-only">(required)</span></label>
							<input
								id="name"
								name="name"
								type="text"
								required
								autocomplete="name"
								aria-required="true"
								placeholder="Ivan"
							/>
						</div>
						<div class="form-field form-field--email">
							<label for="email">Email <span class="sr-only">(required)</span></label>
							<input
								id="email"
								name="email"
								type="email"
								required
								autocomplete="email"
								aria-required="true"
								placeholder="ivan@example.com"
							/>
						</div>
						<div class="form-field form-field--phone">
							<label for="phone">Phone</label>
							<input id="phone" name="phone" type="tel" autocomplete="tel" placeholder="+385…" />
						</div>
						<div class="form-field full">
							<label for="tourSlug">Subject</label>
							<select id="tourSlug" name="tourSlug">
								<option value="">General enquiry</option>
								{
									tours.map((t) => (
										<option value={t.slug} selected={t.slug === selectedTour}>
											{t.title}
										</option>
									))
								}
							</select>
						</div>
						<div class="form-field full">
							<label for="message">Message <span class="sr-only">(required)</span></label>
							<textarea
								id="message"
								name="message"
								required
								aria-required="true"
								placeholder="Tell us what you have in mind — dates, group size, any special requests…"
							></textarea>
						</div>
					</div>
					<button type="submit" class="btn-primary contact-submit">
						Send message
						<i class="ti ti-arrow-right" aria-hidden="true"></i>
					</button>
					<p id="contact-status" role="status" aria-live="polite"></p>
				</form>
			</div>

			<a class="map-stub" href={mapUrl} target="_blank" rel="noopener noreferrer">
				<i class="ti ti-map-2" aria-hidden="true"></i>
				Riva promenade, stand 14 — open in Google Maps
			</a>
			<div class="marina-note">
				<i class="ti ti-info-circle" aria-hidden="true"></i>
				<span>
					Meet at stand 14 on Split’s Riva — look for Hello Blue Cave signage near the boat berths. Arrive ten
					to fifteen minutes before check-in; the waterfront gets busy in peak season.
				</span>
			</div>
		</div>
	</main>
</SiteLayout>

<script>
	import { initContactForm } from '../../client/contact-form';
	initContactForm();
</script>

<style>
	.contact-title {
		font-size: 22px;
		font-weight: 500;
		margin: 0 0 5px;
	}

	.hero-sub {
		font-size: 13px;
		color: var(--color-text-secondary);
		margin: 0 0 24px;
		line-height: 1.6;
	}

	.contact-page .cc-icon--success {
		background: var(--color-background-success);
		color: var(--color-text-success);
	}

	.contact-page .cc-icon--info {
		background: var(--color-background-info);
		color: var(--color-text-info);
	}

	.contact-page .cc-icon--location {
		background: #faeeda;
		color: #633806;
	}

	.contact-page .open-dot {
		background: #1d9e75;
	}

	.hours-note {
		font-size: 12px;
		color: var(--color-text-secondary);
		margin: 8px 0 0;
		line-height: 1.5;
	}

	.contact-page .form-field--name {
		grid-column: 1;
		grid-row: 1;
	}

	.contact-page .form-field--email {
		grid-column: 1;
		grid-row: 2;
	}

	.contact-page .form-field--phone {
		grid-column: 2;
		grid-row: 2;
	}

	.contact-page .form-field input,
	.contact-page .form-field select,
	.contact-page .form-field textarea {
		font-size: 13px;
	}

	.contact-page .form-field textarea {
		resize: vertical;
		min-height: 80px;
	}

	.contact-submit {
		margin-top: 6px;
		padding: 11px 22px;
		font-size: 13px;
		min-height: auto;
	}

	.contact-submit .ti {
		font-size: 13px;
		vertical-align: -2px;
	}

	#contact-status {
		min-height: 1.5em;
		margin: 8px 0 0;
		font-size: 13px;
		font-weight: 500;
	}

	#contact-status:empty {
		min-height: 0;
		margin: 0;
	}

	.contact-page .map-stub {
		height: 140px;
		margin-bottom: 16px;
	}

	.contact-page .map-stub .ti {
		font-size: 20px;
		color: #1d9e75;
	}

	.contact-page .marina-note .ti {
		color: #1d9e75;
	}

	.contact-page .marina-note span {
		margin: 0;
	}

	@media (max-width: 768px) {
		.contact-page .form-field--name,
		.contact-page .form-field--email,
		.contact-page .form-field--phone {
			grid-column: auto;
			grid-row: auto;
		}
	}
</style>
