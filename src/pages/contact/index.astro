---
export const prerender = true;

import { pageTitle, SITE_EMAIL, SITE_NAME, SITE_PHONE, SITE_PHONE_DISPLAY } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getAllTours } from '../../lib/tours';

const tours = getAllTours();
const tourFromQuery = Astro.url.searchParams.get('tour') ?? '';
const selectedTour = tours.some((t) => t.slug === tourFromQuery) ? tourFromQuery : '';
---

<SiteLayout
	title={pageTitle('Contact')}
	description={`Reach ${SITE_NAME} on Split’s Riva — stand 14 — or send a message about tours and private charters.`}
>
	<main id="main" class="page-shell page-shell--form">
		<h1 class="page-title">Contact</h1>
		<p class="page-lead">
			<strong>Meet-up:</strong> Riva promenade of Split, stand number 14 ·
			<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a> ·
			<a href={`tel:${SITE_PHONE}`}>{SITE_PHONE_DISPLAY}</a>
		</p>

		<form id="contact-form" class="form" novalidate>
			<input type="hidden" name="_startedAt" id="contact-started-at" value="" />
			<div class="field field--hp" aria-hidden="true">
				<label for="company">Company</label>
				<input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
			</div>
			<div class="field">
				<label for="name">Name <span class="req" aria-hidden="true">*</span></label>
				<input id="name" name="name" type="text" required autocomplete="name" aria-required="true" />
			</div>
			<div class="field">
				<label for="email">Email <span class="req" aria-hidden="true">*</span></label>
				<input id="email" name="email" type="email" required autocomplete="email" aria-required="true" />
			</div>
			<div class="field">
				<label for="phone">Phone</label>
				<input id="phone" name="phone" type="tel" autocomplete="tel" />
			</div>
			<div class="field">
				<label for="tourSlug">Tour interest (optional)</label>
				<select id="tourSlug" name="tourSlug">
					<option value="">— Select —</option>
					{tours.map((t) => (
						<option value={t.slug} selected={t.slug === selectedTour}>
							{t.title}
						</option>
					))}
				</select>
			</div>
			<div class="field">
				<label for="message">Message <span class="req" aria-hidden="true">*</span></label>
				<textarea id="message" name="message" rows="5" required aria-required="true" placeholder="Dates, group size, questions…"></textarea>
			</div>
			<p class="fine">We typically reply within one business day. For urgent questions, call us on the number above.</p>
			<button type="submit" class="submit">Send message</button>
			<p id="contact-status" class="status" role="status" aria-live="polite"></p>
		</form>
	</main>
</SiteLayout>

<script>
	import { initContactForm } from '../../client/contact-form';
	initContactForm();
</script>

<style>
	.page-lead a {
		font-weight: var(--font-weight-medium);
	}

	.form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.field--hp {
		position: absolute;
		left: -9999px;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	.field label {
		display: block;
		font-weight: var(--font-weight-medium);
		font-size: var(--text-sm);
		margin-bottom: 0.35rem;
		color: var(--color-nav);
	}

	.req {
		color: var(--color-error);
	}

	.field input,
	.field select,
	.field textarea {
		width: 100%;
		min-height: var(--touch-min);
		padding: 0.65rem 0.75rem;
		border-radius: 8px;
		border: 1px solid var(--color-border);
		font: inherit;
		font-size: var(--text-base);
		background: var(--color-surface);
	}

	.field textarea {
		min-height: 8rem;
		resize: vertical;
	}

	.fine {
		margin: 0;
		font-size: var(--text-xs);
		color: var(--color-muted);
	}

	.submit {
		appearance: none;
		border: none;
		cursor: pointer;
		align-self: flex-start;
		min-height: var(--touch-min);
		padding: 0.65rem 1.25rem;
		border-radius: 8px;
		background: var(--color-cta);
		color: var(--color-cta-text);
		font-weight: var(--font-weight-bold);
		font-size: var(--text-base);
	}

	.submit:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	.status {
		min-height: 1.5em;
		margin: 0;
		font-weight: 600;
		color: var(--color-nav-elevated);
	}
</style>
