---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getAllTours } from '../../lib/tours';

const tours = getAllTours();
---

<SiteLayout
	title="Contact — Blue Cave Tours"
	description="Reach Blue Cave Tours on Split’s Riva — stand 14 — or send a message about tours and private charters."
>
	<main id="main" class="main">
		<h1 class="title">Contact</h1>
		<p class="lead">
			<strong>Meet-up:</strong> Riva promenade of Split, stand number 14 ·
			<a href="mailto:info@bluecavetours.com">info@bluecavetours.com</a> ·
			<a href="tel:+385919888838">+385 91 988 88 38</a>
		</p>

		<form id="contact-form" class="form" novalidate>
			<div class="field">
				<label for="name">Name <span class="req">*</span></label>
				<input id="name" name="name" type="text" required autocomplete="name" />
			</div>
			<div class="field">
				<label for="email">Email <span class="req">*</span></label>
				<input id="email" name="email" type="email" required autocomplete="email" />
			</div>
			<div class="field">
				<label for="phone">Phone</label>
				<input id="phone" name="phone" type="tel" autocomplete="tel" />
			</div>
			<div class="field">
				<label for="tourSlug">Tour interest (optional)</label>
				<select id="tourSlug" name="tourSlug">
					<option value="">— Select —</option>
					{tours.map((t) => (
						<option value={t.slug}>
							{t.title}
						</option>
					))}
				</select>
			</div>
			<div class="field">
				<label for="message">Message <span class="req">*</span></label>
				<textarea id="message" name="message" rows="5" required placeholder="Dates, group size, questions…" />
			</div>
			<p class="fine">This demo posts to our server and logs the payload in development — no email provider yet.</p>
			<button type="submit" class="submit">Send message</button>
			<p id="contact-status" class="status" role="status" aria-live="polite"></p>
		</form>
	</main>
</SiteLayout>

<script is:inline>
	const form = document.getElementById('contact-form');
	const statusEl = document.getElementById('contact-status');
	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (!(form instanceof HTMLFormElement) || !statusEl) return;
		const btn = form.querySelector('button[type="submit"]');
		if (btn instanceof HTMLButtonElement) btn.disabled = true;
		statusEl.textContent = 'Sending…';
		const data = Object.fromEntries(new FormData(form).entries());
		try {
			const res = await fetch('/api/contact', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(data),
			});
			const json = await res.json().catch(() => ({}));
			if (!res.ok) throw new Error(json.error || 'Failed to send');
			statusEl.textContent = 'Thanks — we received your message.';
			form.reset();
		} catch (err) {
			statusEl.textContent = err instanceof Error ? err.message : 'Something went wrong';
		} finally {
			if (btn instanceof HTMLButtonElement) btn.disabled = false;
		}
	});
</script>

<style>
	.main {
		max-width: 560px;
		margin: 0 auto;
		padding: 2.5rem 1.25rem 4rem;
	}

	.title {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		color: var(--color-nav);
		margin: 0 0 1rem;
	}

	.lead {
		margin: 0 0 2rem;
		line-height: 1.6;
		color: var(--color-muted);
	}

	.lead a {
		font-weight: 600;
	}

	.form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.field label {
		display: block;
		font-weight: 600;
		font-size: 0.9rem;
		margin-bottom: 0.35rem;
		color: var(--color-nav);
	}

	.req {
		color: #dc2626;
	}

	.field input,
	.field select,
	.field textarea {
		width: 100%;
		padding: 0.6rem 0.75rem;
		border-radius: 8px;
		border: 1px solid var(--color-border);
		font: inherit;
		background: var(--color-surface);
	}

	.field textarea {
		resize: vertical;
		min-height: 120px;
	}

	.fine {
		margin: 0;
		font-size: 0.8125rem;
		color: var(--color-muted);
	}

	.submit {
		appearance: none;
		border: none;
		cursor: pointer;
		align-self: flex-start;
		padding: 0.65rem 1.25rem;
		border-radius: 8px;
		background: var(--color-cta);
		color: var(--color-cta-text);
		font-weight: 700;
		font-size: 1rem;
		font-family: inherit;
	}

	.submit:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	.status {
		min-height: 1.5em;
		margin: 0;
		font-weight: 600;
		color: var(--color-nav-elevated);
	}
</style>
