---
import { pageTitle, SITE_EMAIL, SITE_PHONE, SITE_PHONE_TEL } from '../../config/site';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { t } from '../../i18n';
import { getAllTours } from '../../lib/tours';

const locale = Astro.currentLocale;
const tours = getAllTours();
---

<SiteLayout
	title={pageTitle(t('contact.title', locale))}
	description={t('contact.description', locale)}
>
	<main id="main" class="main">
		<h1 class="title">{t('contact.title', locale)}</h1>
		<p class="lead">
			<strong>{t('contact.lead', locale)}</strong> ·
			<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a> ·
			<a href={`tel:${SITE_PHONE_TEL}`}>{SITE_PHONE}</a>
		</p>

		<form
			id="contact-form"
			class="form"
			novalidate
			data-msg-sending={t('contact.sending', locale)}
			data-msg-success={t('contact.success', locale)}
			data-msg-success-no-email={t('contact.successNoEmail', locale)}
		>
			<div class="field">
				<label for="name">{t('contact.name', locale)} <span class="req">*</span></label>
				<input id="name" name="name" type="text" required autocomplete="name" />
			</div>
			<div class="field">
				<label for="email">{t('contact.email', locale)} <span class="req">*</span></label>
				<input id="email" name="email" type="email" required autocomplete="email" />
			</div>
			<div class="field">
				<label for="phone">{t('contact.phone', locale)}</label>
				<input id="phone" name="phone" type="tel" autocomplete="tel" />
			</div>
			<div class="field">
				<label for="tourSlug">{t('contact.tour', locale)}</label>
				<select id="tourSlug" name="tourSlug">
					<option value="">{t('contact.tourSelect', locale)}</option>
					{tours.map((tour) => (
						<option value={tour.slug}>{tour.title}</option>
					))}
				</select>
			</div>
			<div class="field field--hp" aria-hidden="true">
				<label for="website">Website</label>
				<input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
			</div>
			<div class="field">
				<label for="message">{t('contact.message', locale)} <span class="req">*</span></label>
				<textarea id="message" name="message" rows="5" required placeholder={t('contact.messagePlaceholder', locale)} />
			</div>
			<p class="fine">{t('contact.fine', locale)}</p>
			<button type="submit" class="submit">{t('contact.submit', locale)}</button>
			<p id="contact-status" class="status" role="status" aria-live="polite"></p>
		</form>
	</main>
</SiteLayout>

<script>
	import { initContactForm } from '../../client/contact-form';
	initContactForm();
</script>

<style>
	.main {
		max-width: 560px;
		margin: 0 auto;
		padding: 2.5rem 1.25rem 4rem;
	}

	.title {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		color: var(--color-nav);
		margin: 0 0 1rem;
	}

	.lead {
		margin: 0 0 2rem;
		line-height: 1.6;
		color: var(--color-muted);
	}

	.lead a {
		font-weight: 600;
	}

	.form {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.field label {
		display: block;
		font-weight: 600;
		font-size: 0.9rem;
		margin-bottom: 0.35rem;
		color: var(--color-nav);
	}

	.req {
		color: #dc2626;
	}

	.field input,
	.field select,
	.field textarea {
		width: 100%;
		padding: 0.6rem 0.75rem;
		border-radius: 8px;
		border: 1px solid var(--color-border);
		font: inherit;
		background: var(--color-surface);
	}

	.field textarea {
		resize: vertical;
		min-height: 120px;
	}

	.field--hp {
		position: absolute;
		left: -9999px;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	.fine {
		margin: 0;
		font-size: 0.8125rem;
		color: var(--color-muted);
	}

	.submit {
		appearance: none;
		border: none;
		cursor: pointer;
		align-self: flex-start;
		padding: 0.65rem 1.25rem;
		border-radius: 8px;
		background: var(--color-cta);
		color: var(--color-cta-text);
		font-weight: 700;
		font-size: 1rem;
		font-family: inherit;
	}

	.submit:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	.status {
		min-height: 1.5em;
		margin: 0;
		font-weight: 600;
		color: var(--color-nav-elevated);
	}
</style>
