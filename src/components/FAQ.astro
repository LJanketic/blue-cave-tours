---
import { FAQ_ITEMS } from '../data/faq';

const teaser = FAQ_ITEMS.slice(0, 3);
---

<section class="faq" id="faq" aria-labelledby="faq-heading">
	<div class="faq__inner">
		<h2 id="faq-heading" class="faq__title">FAQ</h2>
		<dl class="faq__list">
			{
				teaser.map((item) => (
					<div class="faq__row">
						<dt>{item.question}</dt>
						<dd>
							{item.link ? (
								<>
									{item.answer}{' '}
									<a href={item.link.href}>{item.link.label}</a>.
								</>
							) : (
								item.answer
							)}
						</dd>
					</div>
				))
			}
		</dl>
		<p class="faq__more">
			<a href="/faq">Full FAQ →</a>
		</p>
	</div>
</section>

<style>
	.faq {
		padding: var(--section-padding-y) var(--page-padding-x) var(--section-padding-y-lg);
		background: var(--color-base);
	}

	.faq__inner {
		max-width: var(--content-narrow);
		margin: 0 auto;
	}

	.faq__more {
		margin: 1.5rem 0 0;
	}

	.faq__more a {
		font-weight: 700;
		color: var(--color-nav-elevated);
	}

	.faq__title {
		margin: 0 0 1.5rem;
		font-family: var(--font-display);
		font-size: var(--text-2xl);
		font-weight: var(--font-weight-bold);
		color: var(--color-nav);
	}

	.faq__list {
		margin: 0;
	}

	.faq__row {
		padding: 1.15rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	.faq__row:first-child {
		border-top: 1px solid var(--color-border);
	}

	dt {
		margin: 0 0 0.35rem;
		font-family: var(--font-display);
		font-size: var(--text-base);
		font-weight: var(--font-weight-medium);
		color: var(--color-nav);
	}

	dd {
		margin: 0;
		font-size: var(--text-sm);
		color: var(--color-muted);
		line-height: 1.55;
	}
</style>
