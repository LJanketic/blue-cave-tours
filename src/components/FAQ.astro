---
import { t } from '../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale;
const faqHref = getRelativeLocaleUrl(locale, '/faq');
---

<section class="faq" id="faq" aria-labelledby="faq-heading">
	<div class="faq__inner">
		<h2 id="faq-heading" class="faq__title">{t('faq.title', locale)}</h2>
		<dl class="faq__list">
			<div class="faq__row">
				<dt>{t('faq.q1', locale)}</dt>
				<dd>{t('faq.a1', locale)}</dd>
			</div>
			<div class="faq__row">
				<dt>{t('faq.q2', locale)}</dt>
				<dd>{t('faq.a2', locale)}</dd>
			</div>
			<div class="faq__row">
				<dt>{t('faq.q3', locale)}</dt>
				<dd>{t('faq.a3', locale)}</dd>
			</div>
		</dl>
		<p class="faq__more">
			<a href={faqHref}>{t('faq.more', locale)}</a>
		</p>
	</div>
</section>

<style>
	.faq {
		padding: 3.5rem 1.25rem 4rem;
		background: var(--color-base);
	}

	.faq__inner {
		max-width: 720px;
		margin: 0 auto;
	}

	.faq__more {
		margin: 1.5rem 0 0;
	}

	.faq__more a {
		font-weight: 700;
		color: var(--color-nav-elevated);
	}

	.faq__title {
		margin: 0 0 1.5rem;
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.125rem);
		font-weight: 700;
		color: var(--color-nav);
	}

	.faq__list {
		margin: 0;
	}

	.faq__row {
		padding: 1.15rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	.faq__row:first-child {
		border-top: 1px solid var(--color-border);
	}

	dt {
		margin: 0 0 0.35rem;
		font-weight: 700;
		color: var(--color-nav);
	}

	dd {
		margin: 0;
		color: var(--color-muted);
		line-height: 1.55;
	}
</style>
