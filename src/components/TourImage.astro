---
import { Picture } from 'astro:assets';
import type { PhotoRef } from '../data/tour-photos';

type Layout = 'hero' | 'card' | 'gallery';

type Props = {
	photo: PhotoRef;
	layout?: Layout;
	priority?: boolean;
	eager?: boolean;
	fadeIn?: boolean;
	class?: string;
};

const { photo, layout = 'card', priority = false, eager = false, fadeIn = false, class: className } = Astro.props;

const sizesByLayout: Record<Layout, string> = {
	hero: '100vw',
	card: '(max-width: 480px) 88vw, (max-width: 900px) 45vw, min(380px, 32vw)',
	gallery: '(max-width: 720px) 100vw, 33vw',
};

const pictureLayout = layout === 'hero' ? 'full-width' : 'none';
const loading = priority || eager ? 'eager' : 'lazy';
---

<div
	class:list={['tour-image', fadeIn && 'tour-image--fade', className]}
	style={`--placeholder: ${photo.color}`}
>
	<Picture
		src={photo.src}
		formats={['avif', 'webp']}
		alt={photo.alt}
		layout={pictureLayout}
		widths={layout === 'hero' ? undefined : [640, 1280]}
		sizes={sizesByLayout[layout]}
		priority={priority}
		loading={loading}
		decoding={priority ? 'sync' : 'async'}
		fit="cover"
		class="tour-image__img"
		data-tour-image={fadeIn ? '' : undefined}
	/>
</div>

<style>
	.tour-image {
		background-color: var(--placeholder, var(--color-border));
		overflow: hidden;
	}

	.tour-image__img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.tour-image--fade .tour-image__img {
		opacity: 0;
		transition: opacity 0.25s ease;
	}

	.tour-image--fade .tour-image__img.is-loaded {
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.tour-image--fade .tour-image__img {
			opacity: 1;
			transition: none;
		}
	}
</style>

{
	fadeIn && (
		<script is:inline>
			(() => {
				const markLoaded = (img) => img.classList.add('is-loaded');
				document.querySelectorAll('.tour-image--fade .tour-image__img').forEach((img) => {
					if (img.complete) markLoaded(img);
					else img.addEventListener('load', () => markLoaded(img), { once: true });
				});
			})();
		</script>
	)
}
