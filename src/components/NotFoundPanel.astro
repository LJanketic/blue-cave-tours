---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<div class="nf">
	<h1 class="nf__title">{title}</h1>
	<p class="nf__lead">{description}</p>
	<div class="nf__actions">
		<slot />
	</div>
</div>

<style>
	.nf {
		max-width: var(--content-form);
		margin: 0 auto;
		padding: var(--page-padding-y) var(--page-padding-x);
	}

	.nf__title {
		margin: 0 0 1rem;
		font-family: var(--font-display);
		font-size: var(--text-2xl);
		font-weight: var(--font-weight-bold);
		color: var(--color-nav);
	}

	.nf__lead {
		margin: 0 0 1rem;
		line-height: 1.55;
		color: var(--color-muted);
	}

	.nf__actions {
		margin: 0;
		line-height: 1.6;
	}

	.nf__actions :global(a) {
		font-weight: 600;
	}
</style>
