---
import { HERO_IMAGE_SRC, HERO_SRCSET_WIDTHS } from '../data/hero-image';
import { unsplashDefaultSrc, unsplashSrcSet } from '../lib/unsplash';
import WaveDivider from './WaveDivider.astro';
import Wordmark from './Wordmark.astro';

const heroSrcSet = unsplashSrcSet(HERO_IMAGE_SRC, HERO_SRCSET_WIDTHS);
const heroSrc = unsplashDefaultSrc(HERO_IMAGE_SRC, 1280);
---

<section class="hero" aria-labelledby="hero-heading">
	<div class="hero__media">
		<img
			src={heroSrc}
			srcset={heroSrcSet}
			sizes="100vw"
			alt=""
			width="1920"
			height="1080"
			fetchpriority="high"
			decoding="async"
		/>
		<div class="hero__overlay" aria-hidden="true"></div>
	</div>
	<div class="hero__content">
		<Wordmark class="hero__wordmark" theme="light" />
		<WaveDivider class="hero__wave" />
		<p class="hero__eyebrow type-label">Your Adriatic adventure starts here</p>
		<h1 id="hero-heading" class="hero__title">Blue Cave &amp; island tours from the heart of Split</h1>
		<p class="hero__lead">
			Step aboard a modern speedboat, feel the sea breeze, and explore hidden bays and iconic islands with a crew that
			prioritizes safety, comfort, and time in the water—not rushing between stops.
		</p>
		<div class="hero__actions">
			<a class="btn btn--primary" href="/tours">See available tours</a>
			<a class="btn btn--ghost" href="/contact">Contact us</a>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: min(85vh, 780px);
		display: grid;
		place-items: center;
		text-align: center;
		color: var(--color-chrome-text);
	}

	.hero__media {
		position: absolute;
		inset: 0;
		overflow: hidden;
	}

	.hero__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(to bottom, var(--color-overlay-light) 0%, var(--color-overlay-mid) 100%),
			linear-gradient(to top, var(--color-overlay-strong) 0%, transparent 50%);
	}

	.hero__content {
		position: relative;
		z-index: 1;
		max-width: 42rem;
		margin: 0 auto;
		padding: var(--page-padding-y) var(--page-padding-x) 3rem;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.hero__wordmark {
		margin-bottom: 0.75rem;
	}

	.hero__wave {
		margin-bottom: 1.25rem;
		color: var(--color-brand-on-primary);
	}

	.hero__eyebrow {
		margin: 0 0 0.75rem;
		font-size: var(--text-sm);
		color: var(--color-chrome-link);
	}

	.hero__title {
		margin: 0 0 1rem;
		max-width: min(32ch, 100%);
		font-family: var(--font-display);
		font-size: var(--text-2xl);
		font-weight: var(--font-weight-bold);
		line-height: 1.2;
		text-wrap: balance;
		color: var(--color-brand-on-primary);
		text-shadow: 0 1px 3px rgb(0 0 0 / 0.35);
	}

	.hero__lead {
		margin: 0 0 1.75rem;
		max-width: min(48ch, 100%);
		font-size: var(--text-lg);
		line-height: 1.65;
		color: var(--color-chrome-text-muted);
		text-shadow: 0 1px 2px rgb(0 0 0 / 0.3);
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		justify-content: center;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.25rem;
		border-radius: 8px;
		font-weight: var(--font-weight-bold);
		font-size: var(--text-base);
		text-decoration: none;
		transition:
			background 0.15s ease,
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.btn--primary {
		background: var(--color-cta);
		color: var(--color-cta-text);
		border: 2px solid transparent;
	}

	.btn--primary:hover {
		background: var(--color-cta-hover);
		color: var(--color-cta-text);
	}

	.btn--ghost {
		background: transparent;
		color: var(--color-brand-on-primary);
		border: 2px solid rgb(255 255 255 / 0.45);
	}

	.btn--ghost:hover {
		border-color: var(--color-brand-on-primary);
		background: rgb(255 255 255 / 0.08);
		color: var(--color-brand-on-primary);
	}

	.btn--ghost:focus-visible {
		outline-color: var(--color-brand-on-primary);
		outline-offset: 3px;
	}

	@media (max-width: 540px) {
		.hero__content {
			padding: 2.25rem var(--page-padding-x) 2.75rem;
		}

		.hero__actions {
			flex-direction: column;
			align-items: stretch;
		}

		.hero__actions .btn {
			width: 100%;
			justify-content: center;
		}
	}
</style>
