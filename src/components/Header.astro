---
import { SITE_NAME } from '../config/site';

type Props = {
	/** When false the bar floats (fixed) over a full-bleed hero (homepage). */
	solid?: boolean;
};

const { solid = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class:list={['nav', !solid && 'nav--floating']} id="site-header" data-floating={String(!solid)}>
	<div class="nav-inner">
		<a class="nav-logo" href="/">
			<i class="ti ti-sailboat" aria-hidden="true"></i>
			{SITE_NAME}
		</a>
		<nav class="nav-links" id="primary-nav" aria-label="Main">
			<button type="button" class="nav-close" id="menu-close" aria-label="Close menu">
				<i class="ti ti-x" aria-hidden="true"></i>
			</button>
			<a class:list={['nav-link', currentPath.startsWith('/tours') && 'nav-link--active']} href="/tours">Tours</a>
			<a class:list={['nav-link', currentPath.startsWith('/destinations') && 'nav-link--active']} href="/destinations">Destinations</a>
			<a class:list={['nav-link', currentPath === '/about' && 'nav-link--active']} href="/about">About</a>
			<a class:list={['nav-link', currentPath.startsWith('/faq') && 'nav-link--active']} href="/faq">FAQ</a>
			<a class:list={['nav-link', currentPath.startsWith('/contact') && 'nav-link--active']} href="/contact">Contact</a>
		</nav>
		<a class="btn-primary nav-cta" href="/tours">Book now</a>
		<button type="button" class="nav-toggle" id="menu-toggle" aria-expanded="false" aria-controls="primary-nav">
			<span class="sr-only">Menu</span>
			<i class="ti ti-menu-2" aria-hidden="true"></i>
		</button>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const toggle = document.getElementById('menu-toggle');
	const closeBtn = document.getElementById('menu-close');
	const nav = document.getElementById('primary-nav');

	if (header && toggle && nav) {
		const headerEl = header;
		const toggleEl = toggle;
		const navEl = nav;

		const focusableSelector =
			'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

		function getFocusables(): HTMLElement[] {
			return Array.from(headerEl.querySelectorAll<HTMLElement>(focusableSelector)).filter(
				(el) => !el.hasAttribute('disabled') && el.offsetParent !== null,
			);
		}

		function setOpen(open: boolean) {
			headerEl.classList.toggle('nav--open', open);
			document.body.classList.toggle('nav-menu-open', open);
			toggleEl.setAttribute('aria-expanded', String(open));
			navEl.setAttribute('aria-modal', open ? 'true' : 'false');
			document.body.style.overflow = open ? 'hidden' : '';

			if (open) {
				const firstNavLink = navEl.querySelector<HTMLElement>('a.nav-link');
				firstNavLink?.focus();
			} else {
				toggleEl.focus();
			}
		}

		function closeMenu() {
			if (headerEl.classList.contains('nav--open')) {
				setOpen(false);
			}
		}

		toggleEl.addEventListener('click', () => {
			setOpen(!headerEl.classList.contains('nav--open'));
		});

		closeBtn?.addEventListener('click', closeMenu);

		document.addEventListener('click', (event) => {
			if (!headerEl.contains(event.target as Node)) {
				closeMenu();
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				closeMenu();
				return;
			}

			if (event.key !== 'Tab' || !headerEl.classList.contains('nav--open')) {
				return;
			}

			const focusables = getFocusables();
			if (focusables.length === 0) {
				return;
			}

			const first = focusables[0];
			const last = focusables[focusables.length - 1];
			const active = document.activeElement;

			if (event.shiftKey && active === first) {
				event.preventDefault();
				last.focus();
			} else if (!event.shiftKey && active === last) {
				event.preventDefault();
				first.focus();
			}
		});

		// Scroll behaviour: solidify past 40px, hide on scroll-down / show on
		// scroll-up (never while the mobile menu is open). rAF-throttled.
		let lastY = window.scrollY;
		let ticking = false;

		function onScroll() {
			const y = window.scrollY;
			headerEl.classList.toggle('nav-solid', y > 40);

			const menuOpen = headerEl.classList.contains('nav--open');
			if (!menuOpen) {
				if (y > lastY && y > 80) {
					headerEl.classList.add('nav-hidden');
				} else {
					headerEl.classList.remove('nav-hidden');
				}
			}
			lastY = y;
			ticking = false;
		}

		window.addEventListener(
			'scroll',
			() => {
				if (!ticking) {
					requestAnimationFrame(onScroll);
					ticking = true;
				}
			},
			{ passive: true },
		);

		onScroll();
	}
</script>
