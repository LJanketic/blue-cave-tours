---
const nav = [
	{ href: '/', label: 'Home' },
	{ href: '/tours', label: 'Tours' },
	{ href: '/#why-us', label: 'Why us' },
	{ href: '/faq', label: 'FAQ' },
	{ href: '/contact', label: 'Contact' },
];
---

<header class="header" id="site-header">
	<div class="header__inner">
		<a class="header__brand" href="/">
			<span class="header__logo" aria-hidden="true">BC</span>
			<span class="header__name">Blue Cave Tours</span>
		</a>

		<nav class="header__nav" id="primary-nav" aria-label="Primary">
			<ul class="header__list">
				{
					nav.map((item) => (
						<li>
							<a href={item.href} class="header__link">
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="header__trailing">
			<a class="header__cta" href="/tours">
				<span class="header__cta-short">Book</span>
				<span class="header__cta-long">Book a tour</span>
			</a>
			<button
				type="button"
				class="header__menu-toggle"
				aria-expanded="false"
				aria-controls="primary-nav"
				id="menu-toggle"
			>
				<span class="sr-only">Menu</span>
				<span class="header__burger" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</span>
			</button>
		</div>
	</div>
</header>

<script is:inline>
	(function () {
		const header = document.getElementById('site-header');
		const btn = document.getElementById('menu-toggle');
		const nav = document.getElementById('primary-nav');
		if (!header || !btn || !nav) return;

		const mq = window.matchMedia('(min-width: 769px)');

		function syncAria() {
			if (mq.matches) {
				nav.removeAttribute('aria-hidden');
				nav.removeAttribute('inert');
			} else {
				const open = header.classList.contains('header--open');
				nav.setAttribute('aria-hidden', String(!open));
				/* inert removes focusables from tab order when menu is closed (Lighthouse / a11y) */
				if (open) nav.removeAttribute('inert');
				else nav.setAttribute('inert', '');
			}
		}

		function setOpen(open) {
			header.classList.toggle('header--open', open);
			btn.setAttribute('aria-expanded', String(open));
			document.body.style.overflow = open ? 'hidden' : '';
			btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
			syncAria();
		}

		btn.addEventListener('click', () => setOpen(!header.classList.contains('header--open')));

		nav.querySelectorAll('a').forEach((a) => {
			a.addEventListener('click', () => setOpen(false));
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && header.classList.contains('header--open')) setOpen(false);
		});

		mq.addEventListener('change', () => {
			if (mq.matches) {
				header.classList.remove('header--open');
				btn.setAttribute('aria-expanded', 'false');
				document.body.style.overflow = '';
				nav.removeAttribute('inert');
			}
			syncAria();
		});

		syncAria();
	})();
</script>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: var(--color-nav);
		color: #f1f5f9;
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
	}

	.header__inner {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: 0.65rem 1rem;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		grid-template-areas:
			'brand trailing'
			'nav nav';
		align-items: center;
		column-gap: 0.75rem;
		row-gap: 0;
	}

	.header__brand {
		grid-area: brand;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		color: inherit;
		text-decoration: none;
		font-weight: 700;
		min-width: 0;
	}

	.header__brand:hover {
		color: #fff;
	}

	.header__logo {
		display: grid;
		place-items: center;
		flex-shrink: 0;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 8px;
		background: linear-gradient(145deg, var(--color-cta), #fb923c);
		color: var(--color-cta-text);
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: -0.02em;
	}

	.header__name {
		font-family: var(--font-display);
		font-size: 0.9375rem;
		line-height: 1.2;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.header__nav {
		grid-area: nav;
		overflow: hidden;
		max-height: 0;
		transition: max-height 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		border-top: 1px solid transparent;
	}

	.header--open .header__nav {
		max-height: 22rem;
		border-top-color: rgba(255, 255, 255, 0.1);
		margin-top: 0.65rem;
		padding-top: 0.35rem;
	}

	.header__list {
		display: flex;
		flex-direction: column;
		gap: 0;
		list-style: none;
		margin: 0;
		padding: 0 0 0.5rem;
	}

	.header__list li {
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.header__link {
		display: block;
		padding: 0.85rem 0;
		color: #e2e8f0;
		text-decoration: none;
		font-weight: 600;
		font-size: 1rem;
	}

	.header__link:hover,
	.header__link:focus-visible {
		color: #fff;
	}

	.header__trailing {
		grid-area: trailing;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.625rem;
		flex-shrink: 0;
		align-self: center;
	}

	.header__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.5rem;
		padding: 0.45rem 1rem;
		border-radius: 8px;
		background: var(--color-cta);
		color: var(--color-cta-text);
		font-weight: 700;
		font-size: 0.9375rem;
		text-decoration: none;
		white-space: nowrap;
		transition: background 0.15s ease;
	}

	.header__cta-long {
		display: none;
	}

	.header__cta:hover {
		background: var(--color-cta-hover);
		color: var(--color-cta-text);
	}

	.header__menu-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		min-width: 2.5rem;
		min-height: 2.5rem;
		padding: 0;
		border: none;
		border-radius: 8px;
		background: transparent;
		cursor: pointer;
		color: #fff;
		transition: background 0.15s ease;
	}

	.header__menu-toggle:hover {
		background: rgba(255, 255, 255, 0.1);
	}

	.header__menu-toggle:focus-visible {
		outline: 2px solid var(--color-cta);
		outline-offset: 2px;
	}

	.header__burger {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 1.125rem;
	}

	.header__burger span {
		display: block;
		height: 2px;
		background: #fff;
		border-radius: 1px;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}

	.header--open .header__burger span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.header--open .header__burger span:nth-child(2) {
		opacity: 0;
	}

	.header--open .header__burger span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	/* Desktop: single row, centered nav, no hamburger */
	@media (min-width: 769px) {
		.header__inner {
			display: flex;
			flex-direction: row;
			flex-wrap: nowrap;
			align-items: center;
			justify-content: space-between;
			gap: 1rem;
			padding: 0.875rem 1.25rem;
		}

		.header__nav {
			flex: 1;
			display: flex;
			justify-content: center;
			max-height: none !important;
			overflow: visible !important;
			margin-top: 0 !important;
			padding-top: 0 !important;
			border-top: none !important;
		}

		.header__list {
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.35rem 1.5rem;
			padding: 0;
		}

		.header__list li {
			border-bottom: none;
		}

		.header__link {
			display: inline;
			padding: 0.35rem 0;
			font-size: 0.9375rem;
			color: #cbd5e1;
		}

		.header__menu-toggle {
			display: none;
		}

		.header__cta {
			font-size: 0.9375rem;
			padding: 0.5rem 1rem;
			min-height: unset;
		}

		.header__cta-short {
			display: none;
		}

		.header__cta-long {
			display: inline;
		}

		.header__name {
			white-space: nowrap;
		}
	}
</style>
