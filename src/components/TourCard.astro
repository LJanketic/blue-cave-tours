---
import type { TourDetail } from '../types/tour';
import { unsplashDefaultSrc, unsplashSrcSet } from '../lib/unsplash';
import { supportsOnlineCheckout, contactHrefForTour } from '../lib/booking';

type Props = { tour: TourDetail };

const { tour } = Astro.props;
const online = supportsOnlineCheckout(tour);
const cardSrcSet = unsplashSrcSet(tour.image.src, [400, 640, 960, 1200]);
const cardSrc = unsplashDefaultSrc(tour.image.src, 800);
---

<article class="card" id={tour.slug}>
	<div class="card__image">
		<a href={`/tours/${tour.slug}`} class="card__image-link">
			<img
				src={cardSrc}
				srcset={cardSrcSet}
				sizes="(max-width: 480px) 88vw, (max-width: 900px) 45vw, min(380px, 32vw)"
				alt={tour.image.alt}
				width="600"
				height="400"
				loading="lazy"
				decoding="async"
			/>
		</a>
	</div>
	<div class="card__body">
		<p class="card__meta">{tour.scheduleLabel} · {tour.duration}</p>
		<h3 class="card__title">
			<a href={`/tours/${tour.slug}`}>{tour.title}</a>
		</h3>
		<p class="card__tagline">{tour.tagline}</p>
		<p class="card__desc">{tour.shortDescription}</p>
		<div class="card__footer">
			<span class="card__price">From <strong>{tour.fromPrice}</strong></span>
			<div class="card__actions">
				<a class="card__secondary" href={`/tours/${tour.slug}`} aria-label={`Tour details: ${tour.title}`}>
					Details
				</a>
				{
					online ? (
						<form class="checkout-form" data-tour-id={tour.slug}>
							<button type="submit" class="card__cta" aria-label={`Book now: ${tour.title}`}>
								Book now
							</button>
						</form>
					) : (
						<a class="card__cta card__cta--link" href={contactHrefForTour(tour)}>
							Request a quote
						</a>
					)
				}
			</div>
		</div>
	</div>
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: var(--color-surface);
		border-radius: var(--radius);
		overflow: hidden;
		box-shadow: var(--shadow-card);
		border: 1px solid var(--color-border);
		height: 100%;
	}

	.card__image-link {
		display: block;
		text-decoration: none;
	}

	.card__image img {
		width: 100%;
		aspect-ratio: 3 / 2;
		object-fit: cover;
	}

	.card__body {
		padding: 1.25rem 1.35rem 1.35rem;
		display: flex;
		flex-direction: column;
		flex: 1;
		gap: 0.35rem;
	}

	.card__meta {
		margin: 0;
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--color-muted);
	}

	.card__title {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: var(--font-weight-bold);
		line-height: 1.25;
	}

	.card__title a {
		color: var(--color-nav);
		text-decoration: none;
	}

	.card__title a:hover {
		color: var(--color-nav-elevated);
		text-decoration: underline;
	}

	.card__tagline {
		margin: 0;
		font-weight: 600;
		color: var(--color-nav-elevated);
		font-size: 0.95rem;
	}

	.card__desc {
		margin: 0.25rem 0 0;
		flex: 1;
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.55;
	}

	.card__footer {
		margin-top: 1.25rem;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.card__price {
		font-size: 0.9375rem;
		color: var(--color-text);
	}

	.card__price strong {
		font-size: 1.125rem;
		color: var(--color-nav);
	}

	.card__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
	}

	.card__secondary {
		display: inline-flex;
		align-items: center;
		min-height: var(--touch-min);
		padding: 0.6rem 0.9rem;
		border-radius: 8px;
		border: 1px solid var(--color-border);
		color: var(--color-nav);
		font-weight: 700;
		font-size: 0.875rem;
		text-decoration: none;
	}

	.card__secondary:hover {
		border-color: var(--color-nav-elevated);
		background: var(--color-base);
	}

	.checkout-form {
		margin: 0;
	}

	.card__cta {
		appearance: none;
		border: none;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: var(--touch-min);
		padding: 0.6rem 1.1rem;
		border-radius: 8px;
		background: var(--color-cta);
		color: var(--color-cta-text);
		font-weight: 700;
		font-size: 0.9375rem;
		transition: background 0.15s ease;
	}

	.card__cta:hover {
		background: var(--color-cta-hover);
	}

	.card__cta:disabled {
		opacity: 0.65;
		cursor: not-allowed;
	}

	.card__cta--link {
		text-decoration: none;
	}
</style>
