---
import type { TourDetail } from '../types/tour';
import { contactHrefForTour, supportsInstantBook } from '../lib/booking';
import PlaceholderImage from './PlaceholderImage.astro';

type Props = {
	tour: TourDetail;
	featured?: boolean;
};

const { tour, featured = false } = Astro.props;
const instantBook = supportsInstantBook(tour);
const photoIcon = tour.slug.includes('private') || !instantBook ? 'crown' : tour.slug.includes('lagoon') ? 'swimming' : 'sailboat';
---

<article class:list={['tour-card', featured && 'featured']}>
	<a href={`/tours/${tour.slug}`} class="tour-card__link">
		<div class="tc-img card-img">
			<PlaceholderImage photo={tour.image} layout="card" icon={photoIcon} />
			<div class="img-badges">
				{featured && <span class="tc-badge img-badge badge-bestseller">Best seller</span>}
				{instantBook ? (
					<span class="tc-badge img-badge badge-group">Group</span>
				) : (
					<span class="tc-badge img-badge badge-private">Private</span>
				)}
			</div>
		</div>
		<div class="tc-body card-body">
			<p class="tc-name card-title">{tour.title}</p>
			<div class="tc-meta card-meta">
				<span class="meta-item"><i class="ti ti-clock"></i> {tour.duration}</span>
				<span class="meta-item">
					<i class={`ti ti-${instantBook ? 'users' : 'crown'}`}></i>
					{instantBook ? 'Group tour' : 'Private charter'}
				</span>
			</div>
			<p class="card-desc">{tour.shortDescription}</p>
			<div class="tc-foot card-footer">
				<div>
					<span class="price-from">From </span>
					<span class="tc-price price-val">{tour.fromPrice}</span>
					<span class="price-per"> / person</span>
				</div>
			</div>
		</div>
	</a>
	<div class="tour-card__actions">
		<a class="btn-secondary tour-card__details" href={`/tours/${tour.slug}`}>Details</a>
		{
			instantBook ? (
				<form class="booking-form" data-tour-id={tour.slug}>
					<button type="submit" class="btn-primary">Book now</button>
				</form>
			) : (
				<a class="btn-primary" href={contactHrefForTour(tour)}>Request a quote</a>
			)
		}
	</div>
</article>
