---
import { SITE_EMAIL, SITE_NAME, SITE_PHONE, SITE_PHONE_DISPLAY } from '../config/site';
---

<div class="footer-shell">
<footer class="footer">
	<div class="footer-brand">
		<div class="nav-logo">
			<i class="ti ti-sailboat" aria-hidden="true"></i>
			{SITE_NAME}
		</div>
		<p>
			Speedboat tours and private charters from Split. Licensed crew, small groups, and the best of the Adriatic
			islands.
		</p>
		<p class="footer-contact">
			<a href={`tel:${SITE_PHONE}`}>{SITE_PHONE_DISPLAY}</a>
			{' · '}
			<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a>
			<br />
			Riva promenade, stand 14, Split
		</p>
	</div>
	<div class="footer-col">
		<h4>Tours</h4>
		<a href="/tours">All tours</a>
		<a href="/tours/create-perfect-day-private">Private charter</a>
		<a href="/tours/blue-cave-hvar-5-islands">Blue Cave &amp; islands</a>
		<a href="/tours/blue-lagoon-morning">Blue Lagoon</a>
	</div>
	<div class="footer-col">
		<h4>Explore</h4>
		<a href="/destinations">Destinations</a>
		<a href="/about">About us</a>
		<a href="/faq">FAQs</a>
		<a href="/contact">Contact</a>
	</div>
	<div class="footer-col">
		<h4>Legal</h4>
		<a href="/legal/terms">Terms &amp; conditions</a>
		<a href="/legal/privacy">Privacy policy</a>
		<a href="/legal/cancellation">Cancellation policy</a>
	</div>
</footer>
<div class="footer-bottom">
	<span>&copy; {new Date().getFullYear()} {SITE_NAME}</span>
	<span>Licensed maritime operator · Croatia</span>
</div>
</div>
