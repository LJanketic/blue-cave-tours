---
const year = new Date().getFullYear();
---

<footer class="foot" id="contact">
	<div class="foot__inner">
		<div class="foot__brand">
			<p class="foot__name">Blue Cave Tours</p>
			<p class="foot__address">
				Riva promenade of Split, stand number 14<br />
				Split, Croatia
			</p>
			<p class="foot__contact">
				<a href="mailto:info@bluecavetours.com">info@bluecavetours.com</a><br />
				<a href="tel:+385919888838">+385 91 988 88 38</a>
			</p>
			<p class="foot__social">
				<a href="https://www.instagram.com/" rel="noopener noreferrer" target="_blank">Instagram</a>
				<span class="foot__social-sep" aria-hidden="true">·</span>
				<a href="https://www.facebook.com/" rel="noopener noreferrer" target="_blank">Facebook</a>
			</p>
			<p class="foot__ops">
				Operators may include Misericordia d.o.o., Aliskaf d.o.o., Per Mare d.o.o. — named on the planning board; the
				contracting entity appears on your confirmation.
			</p>
		</div>
		<div class="foot__cols">
			<div>
				<h2 class="foot__heading">Quick links</h2>
				<ul class="foot__links">
					<li><a href="/tours">Tours</a></li>
					<li><a href="/#why-us">About the experience</a></li>
					<li><a href="/booking/details">Booking details</a></li>
					<li><a href="/tours/create-perfect-day-private">Private tour</a></li>
				</ul>
			</div>
			<div>
				<h2 class="foot__heading">Legal</h2>
				<ul class="foot__links">
					<li><a href="/legal/terms">Terms &amp; Conditions</a></li>
					<li><a href="/legal/privacy">Privacy Policy</a></li>
				</ul>
			</div>
		</div>
	</div>
	<p class="foot__fine">&copy; {year} Blue Cave Tours · Checkout: Stripe when configured, or demo mode (see <code>CHECKOUT_MODE</code>).</p>
</footer>

<style>
	.foot {
		background: var(--color-nav);
		color: #cbd5e1;
		padding: 3rem 1.25rem 1.5rem;
	}

	.foot__inner {
		max-width: var(--content-max);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2.5rem;
		align-items: start;
	}

	.foot__name {
		margin: 0 0 0.75rem;
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		color: #fff;
	}

	.foot__address,
	.foot__contact,
	.foot__social,
	.foot__ops {
		margin: 0 0 0.75rem;
		font-size: 0.9375rem;
		line-height: 1.55;
	}

	.foot__ops {
		font-size: 0.8125rem;
		color: #94a3b8;
		max-width: 52ch;
	}

	.foot__contact a,
	.foot__social a {
		color: #fdba74;
		text-decoration: none;
		font-weight: 600;
	}

	.foot__contact a:hover,
	.foot__social a:hover {
		color: #fff;
		text-decoration: underline;
	}

	.foot__social-sep {
		margin: 0 0.35rem;
		color: #64748b;
		font-weight: 400;
	}

	.foot__cols {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.foot__heading {
		margin: 0 0 0.75rem;
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #94a3b8;
	}

	.foot__links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.foot__links a {
		color: #e2e8f0;
		text-decoration: none;
		font-size: 0.9375rem;
	}

	.foot__links a:hover {
		color: #fff;
		text-decoration: underline;
	}

	.foot__fine {
		max-width: var(--content-max);
		margin: 2.5rem auto 0;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(255, 255, 255, 0.12);
		font-size: 0.8125rem;
		color: #94a3b8;
		text-align: center;
	}

	.foot__fine code {
		font-size: 0.75em;
		background: rgba(255, 255, 255, 0.08);
		padding: 0.1em 0.35em;
		border-radius: 4px;
	}

	@media (max-width: 720px) {
		.foot__inner {
			grid-template-columns: 1fr;
		}
	}
</style>
