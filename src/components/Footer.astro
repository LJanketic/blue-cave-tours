---
import { SITE_NAME } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="foot" id="site-footer">
	<div class="foot__inner">
		<div class="foot__brand">
			<p class="foot__name">{SITE_NAME}</p>
			<p class="foot__address">
				Riva promenade of Split, stand number 14<br />
				Split, Croatia
			</p>
			<p class="foot__contact">
				<a href="mailto:info@bluecavetours.com">info@bluecavetours.com</a><br />
				<a href="tel:+385919888838">+385 91 988 88 38</a>
			</p>
			<p class="foot__social">
				<a href="https://www.instagram.com/" rel="noopener noreferrer" target="_blank">Instagram</a>
				<span class="foot__social-sep" aria-hidden="true">·</span>
				<a href="https://www.facebook.com/" rel="noopener noreferrer" target="_blank">Facebook</a>
			</p>
			<p class="foot__ops">
				Operators may include Misericordia d.o.o., Aliskaf d.o.o., Per Mare d.o.o. The contracting entity appears on your
				confirmation.
			</p>
		</div>
		<div class="foot__cols">
			<div>
				<h2 class="foot__heading type-label">Quick links</h2>
				<ul class="foot__links">
					<li><a href="/tours">Tours</a></li>
					<li><a href="/#why-us">About the experience</a></li>
					<li><a href="/booking/details">Booking details</a></li>
					<li><a href="/tours/create-perfect-day-private">Private tour</a></li>
				</ul>
			</div>
			<div>
				<h2 class="foot__heading type-label">Legal</h2>
				<ul class="foot__links">
					<li><a href="/legal/terms">Terms &amp; Conditions</a></li>
					<li><a href="/legal/privacy">Privacy Policy</a></li>
				</ul>
			</div>
		</div>
	</div>
	<p class="foot__fine">&copy; {year} {SITE_NAME}</p>
</footer>

<style>
	.foot {
		background: var(--color-chrome-bg);
		color: var(--color-chrome-text-muted);
		padding: var(--section-padding-y-lg) var(--page-padding-x) 1.5rem;
	}

	.foot__inner {
		max-width: var(--content-max);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2.5rem;
		align-items: start;
	}

	.foot__name {
		margin: 0 0 0.75rem;
		font-family: var(--font-display);
		font-size: var(--text-xl);
		font-weight: var(--font-weight-bold);
		color: var(--color-brand-on-primary);
	}

	.foot__address,
	.foot__contact,
	.foot__social,
	.foot__ops {
		margin: 0 0 0.75rem;
		font-size: var(--text-sm);
		line-height: 1.55;
	}

	.foot__ops {
		font-size: var(--text-xs);
		color: var(--color-chrome-text-muted);
		max-width: 52ch;
	}

	.foot__contact a,
	.foot__social a {
		color: var(--color-chrome-link);
		text-decoration: none;
		font-weight: 600;
	}

	.foot__contact a:hover,
	.foot__social a:hover {
		color: var(--color-brand-on-primary);
		text-decoration: underline;
	}

	.foot__social-sep {
		margin: 0 0.35rem;
		color: var(--color-chrome-text-subtle);
		font-weight: 400;
	}

	.foot__cols {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.foot__heading {
		margin: 0 0 0.75rem;
		font-size: var(--text-xs);
		color: var(--color-chrome-text-subtle);
	}

	.foot__links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.foot__links a {
		color: var(--color-chrome-text-muted);
		text-decoration: none;
		font-size: var(--text-sm);
		display: inline-block;
		padding-block: 0.2rem;
	}

	.foot__links a:hover {
		color: var(--color-brand-on-primary);
		text-decoration: underline;
	}

	.foot__fine {
		max-width: var(--content-max);
		margin: 2.5rem auto 0;
		padding: 1.25rem var(--page-padding-x) 0;
		border-top: 1px solid var(--color-chrome-border);
		font-size: var(--text-xs);
		color: var(--color-chrome-text-muted);
		text-align: center;
	}

	@media (max-width: 720px) {
		.foot__inner {
			grid-template-columns: 1fr;
		}
	}
</style>
