---
import { t } from '../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale;
const bookingDetailsHref = getRelativeLocaleUrl(locale, '/booking/details');
---

<section class="why" id="why-us" aria-labelledby="why-heading">
	<div class="why__inner">
		<h2 id="why-heading" class="why__title">{t('why.title', locale)}</h2>
		<ul class="why__list">
			<li>
				<h3 class="why__item-title">{t('why.crewTitle', locale)}</h3>
				<p class="why__item-text">{t('why.crewText', locale)}</p>
			</li>
			<li>
				<h3 class="why__item-title">{t('why.boatsTitle', locale)}</h3>
				<p class="why__item-text">{t('why.boatsText', locale)}</p>
			</li>
			<li>
				<h3 class="why__item-title">{t('why.meetingTitle', locale)}</h3>
				<p class="why__item-text">{t('why.meetingText', locale)}</p>
			</li>
		</ul>
		<p class="why__extra">
			<a href={bookingDetailsHref}>{t('why.bookingLink', locale)}</a>
		</p>
	</div>
</section>

<style>
	.why {
		padding: 3.5rem 1.25rem;
		background: var(--color-surface);
		border-block: 1px solid var(--color-border);
	}

	.why__inner {
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.why__title {
		margin: 0 0 1.75rem;
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.125rem);
		font-weight: 700;
		color: var(--color-nav);
	}

	.why__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.5rem;
	}

	.why__item-title {
		margin: 0 0 0.5rem;
		font-size: 1.0625rem;
		font-weight: 700;
		color: var(--color-nav);
	}

	.why__item-text {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.975rem;
		line-height: 1.55;
	}

	.why__extra {
		margin: 1.75rem 0 0;
	}

	.why__extra a {
		font-weight: 700;
		color: var(--color-nav-elevated);
	}
</style>
