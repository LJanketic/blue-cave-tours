---
type Props = {
	theme?: 'light' | 'dark';
	class?: string;
};

const { theme = 'light', class: className } = Astro.props;
---

<svg
	class:list={['wordmark', `wordmark--${theme}`, className]}
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 380 48"
	fill="none"
	aria-hidden="true"
>
	<text
		x="190"
		y="34"
		fill="currentColor"
		font-family="Glorich, system-ui, sans-serif"
		font-size="22"
		font-weight="700"
		letter-spacing="0.12em"
		text-anchor="middle">HELLO BLUE CAVE</text>
</svg>

<style>
	.wordmark {
		display: block;
		width: min(100%, 22rem);
		height: auto;
	}

	.wordmark--light {
		color: var(--color-brand-on-primary);
	}

	.wordmark--dark {
		color: var(--color-brand-primary);
	}
</style>
