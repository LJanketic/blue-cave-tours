---
import TourCard from './TourCard.astro';
import TourCarousel from './TourCarousel.astro';
import { getFeaturedTours } from '../lib/tours';

const featured = getFeaturedTours();
---

<section class="section" id="tours" aria-labelledby="tours-heading">
	<div class="section__inner">
		<div class="section__head">
			<h2 id="tours-heading" class="section__title">Featured tours</h2>
			<p class="section__sub">
				Five highlighted routes — see the <a href="/tours">full catalog</a> for all tours (availability, half-day and
				full-day windows, private charter).
			</p>
		</div>
		<TourCarousel ariaLabel="Featured tours">
			{
				featured.map((tour) => (
					<li class="tour-carousel__slide">
						<TourCard tour={tour} />
					</li>
				))
			}
		</TourCarousel>
		<p class="section__more">
			<a class="section__more-link" href="/tours">Browse all tours →</a>
		</p>
	</div>
</section>

<style>
	.section {
		padding: 4rem 1.25rem 4.5rem;
		background: linear-gradient(180deg, var(--color-base) 0%, #eef2f7 100%);
	}

	.section__inner {
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.section__head {
		max-width: 62ch;
		margin-bottom: 2rem;
	}

	.section__title {
		margin: 0 0 0.75rem;
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		font-weight: 700;
		color: var(--color-nav);
	}

	.section__sub {
		margin: 0;
		color: var(--color-muted);
		font-size: 1.0625rem;
		line-height: 1.6;
	}

	.section__sub a {
		font-weight: 600;
	}

	.section__more {
		margin: 2rem 0 0;
		text-align: center;
	}

	.section__more-link {
		font-weight: 700;
		color: var(--color-nav-elevated);
		text-decoration: none;
		font-size: 1.0625rem;
	}

	.section__more-link:hover {
		text-decoration: underline;
	}

	@media (max-width: 640px) {
		.section {
			padding: 2.75rem 1.25rem 3.25rem;
		}

		.section__head {
			margin-bottom: 1.5rem;
		}
	}
</style>
