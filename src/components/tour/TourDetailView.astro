---
import type { TourDetail } from '../../types/tour';
import { contactHrefForTour, supportsInstantBook } from '../../lib/booking';
import ImageGallery from '../vue/ImageGallery.vue';

type Props = { tour: TourDetail };

const { tour } = Astro.props;
const instantBook = supportsInstantBook(tour);

const galleryPhotos = [tour.image, ...tour.gallery].map((photo, index) => ({
	color: photo.color,
	alt: photo.alt,
	icon:
		index === 0
			? tour.slug.includes('lagoon')
				? 'swimming'
				: tour.slug.includes('private')
					? 'crown'
					: 'sailboat'
			: ['anchor', 'sunset', 'fish', 'building-lighthouse'][index % 4],
}));

const heroPhoto = galleryPhotos[0];
const thumbPhotos = galleryPhotos.slice(1);

const highlightIcons = ['sunset-2', 'swimming', 'bottle', 'binoculars', 'ship', 'accessible', 'sailboat', 'droplet'];
const itineraryIcons = ['map-pin', 'sailboat', 'swimming', 'sunset', 'anchor', 'building-lighthouse', 'droplet'];

const goodToKnow = [
	{ label: 'Duration', value: tour.duration },
	{ label: 'Departure', value: tour.departure },
	{ label: 'Return', value: tour.returnTime },
	{ label: 'Season', value: tour.availability },
	{ label: 'Meeting point', value: tour.meetingPoint },
	{ label: 'What to bring', value: tour.whatToBring.join(', ') },
];

if (tour.caveTicketNote) {
	goodToKnow.push({ label: 'Cave entry', value: tour.caveTicketNote });
}

const availPattern = [
	'dot-ok',
	'dot-ok',
	'dot-ok',
	'dot-few',
	'dot-few',
	'dot-no',
	'dot-no',
	'dot-ok',
	'dot-ok',
	'dot-ok',
	'dot-few',
	'dot-ok',
	'dot-ok',
	'dot-no',
] as const;
---

<article class="page tour-detail">
	<nav class="breadcrumb" aria-label="Breadcrumb">
		<a href="/tours">Tours</a>
		<span aria-hidden="true"> › </span>
		<a href="/tours">{tour.tagline}</a>
		<span aria-hidden="true"> › </span>
		<span aria-current="page">{tour.title}</span>
	</nav>

	<ImageGallery client:visible hero={heroPhoto} gallery={thumbPhotos} />

	<div class="tags">
		{
			instantBook ? (
				<span class="tag tag-grp">
					<i class="ti ti-users" aria-hidden="true"></i> Group tour
				</span>
			) : (
				<span class="tag tag-priv">
					<i class="ti ti-crown" aria-hidden="true"></i> Private charter
				</span>
			)
		}
		{
			instantBook && (
				<span class="tag tag-priv">
					<i class="ti ti-crown" aria-hidden="true"></i> Private available
				</span>
			)
		}
		<span class="tag tag-dur">
			<i class="ti ti-clock" aria-hidden="true"></i> {tour.duration}
		</span>
		{tour.featured && (
			<span class="tag tag-dur">
				<i class="ti ti-star" aria-hidden="true"></i> Best seller
			</span>
		)}
	</div>

	<div class="layout">
		<div>
			<h1>{tour.title}</h1>
			<p class="rating-row">
				<span><strong>{tour.tagline}</strong></span>
				<span aria-hidden="true">·</span>
				<span>{tour.scheduleLabel}</span>
			</p>

			<section class="section" aria-labelledby="overview-heading">
				<h2 id="overview-heading" class="section-title">Overview</h2>
				<p class="prose">{tour.overviewHighlights}</p>
			</section>

			<section class="section" aria-labelledby="highlights-heading">
				<h2 id="highlights-heading" class="section-title">Highlights</h2>
				<div class="highlights">
					{
						tour.included.map((item, index) => (
							<div class="hl-item">
								<i
									class={`ti ti-${highlightIcons[index % highlightIcons.length]}`}
									aria-hidden="true"
								></i>
								{item}
							</div>
						))
					}
				</div>
			</section>

			<section class="section" aria-labelledby="itinerary-heading">
				<h2 id="itinerary-heading" class="section-title">{tour.itineraryLabel}</h2>
				{
					tour.itinerary.map((step, index) => {
						const isFirst = index === 0;
						const isLast = index === tour.itinerary.length - 1;
						const timeLabel = isFirst ? tour.scheduleLabel : isLast ? tour.returnTime : null;

						return (
							<div class={`itinerary-item${isLast ? ' itinerary-item--last' : ''}`}>
								<div class="it-dot">
									<i class={`ti ti-${itineraryIcons[index % itineraryIcons.length]}`} aria-hidden="true"></i>
								</div>
								<div>
									{timeLabel && <p class="it-time">{timeLabel}</p>}
									<p class="it-label">{step}</p>
								</div>
							</div>
						);
					})
				}
			</section>

			<section class="section" aria-labelledby="included-heading">
				<h2 id="included-heading" class="section-title">What&apos;s included</h2>
				<div class="includes-grid">
					{
						tour.included.map((item) => (
							<div class="inc-item yes">
								<i class="ti ti-circle-check" aria-hidden="true"></i>
								{item}
							</div>
						))
					}
					{
						tour.notIncluded.map((item) => (
							<div class="inc-item no">
								<i class="ti ti-circle-x" aria-hidden="true"></i>
								{item}
							</div>
						))
					}
				</div>
			</section>

			<section class="section" aria-labelledby="know-heading">
				<h2 id="know-heading" class="section-title">Good to know</h2>
				<div class="info-grid">
					{
						goodToKnow.map((item) => (
							<div class="info-item">
								<span class="info-label">{item.label}</span>
								<span class="info-val">{item.value}</span>
							</div>
						))
					}
				</div>
				<p class="prose tour-detail__note">{tour.importantInfo}</p>
			</section>

			{
				tour.disclaimers.length > 0 && (
					<section class="section" aria-labelledby="disclaimers-heading">
						<h2 id="disclaimers-heading" class="section-title">Please note</h2>
						<ul class="tour-detail__disclaimers">
							{tour.disclaimers.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</section>
				)
			}
		</div>

		<aside aria-label="Book this tour">
			<div class="sticky-card">
				<div class="price-row">
					<span class="price-from">From</span>
					<span class="price-val">{tour.fromPrice}</span>
					<span class="price-per">{instantBook ? '/ person' : '/ boat'}</span>
				</div>
				<p class="sticky-card__price-note">{tour.priceNotes}</p>

				<div class="card-row">
					<span class="card-label"><i class="ti ti-calendar" aria-hidden="true"></i> Next departure</span>
					<span class="card-val">{tour.departure}</span>
				</div>
				<div class="card-row">
					<span class="card-label"><i class="ti ti-users" aria-hidden="true"></i> Season</span>
					<span class="card-val">{tour.availability}</span>
				</div>

				<div class="avail-dots" aria-hidden="true">
					{availPattern.map((state) => (
						<div class={`dot ${state}`}></div>
					))}
				</div>
				<div class="dot-legend" aria-hidden="true">
					<span><span class="dot dot-ok"></span> Available</span>
					<span><span class="dot dot-few"></span> Few spots</span>
					<span><span class="dot dot-no"></span> Full</span>
				</div>

				<hr class="card-divider" />

				{
					instantBook ? (
						<form class="booking-form" data-tour-id={tour.slug}>
							<button type="submit" class="cta-primary">
								Book group tour
								<i class="ti ti-arrow-right" aria-hidden="true"></i>
							</button>
						</form>
					) : (
						<a class="cta-primary cta-primary--link" href={contactHrefForTour(tour)}>
							Request a quote
							<i class="ti ti-arrow-right" aria-hidden="true"></i>
						</a>
					)
				}
				{
					instantBook && (
						<a class="cta-secondary" href="/contact?tour=create-perfect-day-private">
							<i class="ti ti-crown" aria-hidden="true"></i>
							Book as private charter
						</a>
					)
				}

				<p class="policy-pill">
					<i class="ti ti-shield-check" aria-hidden="true"></i>
					Free cancellation up to 48h before
				</p>
			</div>
		</aside>
	</div>
</article>

<style>
	.tour-detail h1 {
		font-size: 20px;
		font-weight: 500;
		margin: 0 0 6px;
	}

	.tour-detail .rating-row {
		margin-bottom: 16px;
	}

	.tour-detail .rating-row strong {
		color: var(--color-text-primary);
	}

	.tour-detail .sticky-card .price-from {
		font-size: 12px;
	}

	.tour-detail .sticky-card .price-val {
		font-size: 22px;
		font-weight: 500;
	}

	.tour-detail .sticky-card .price-per {
		font-size: 12px;
	}

	.tour-detail .sticky-card .card-row:last-of-type {
		margin-bottom: 0;
	}

	.tour-detail .avail-dots {
		display: flex;
		gap: 3px;
		flex-wrap: wrap;
		margin-top: 8px;
	}

	.tour-detail .dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.tour-detail .dot-ok {
		background: #1d9e75;
	}

	.tour-detail .dot-few {
		background: #ef9f27;
	}

	.tour-detail .dot-no {
		background: var(--color-border-secondary);
	}

	.tour-detail .dot-legend {
		display: flex;
		gap: 10px;
		margin-top: 6px;
		font-size: 11px;
		color: var(--color-text-tertiary);
		flex-wrap: wrap;
	}

	.tour-detail .dot-legend span {
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.tour-detail .dot-legend .dot {
		display: inline-block;
	}

	.tour-detail .hl-item .ti {
		color: #1d9e75;
	}

	.tour-detail .itinerary-item--last {
		padding-bottom: 0;
	}

	.tour-detail .booking-form {
		margin: 0;
		width: 100%;
	}

	.tour-detail__note {
		margin-top: 12px;
	}

	.tour-detail__disclaimers {
		margin: 0;
		padding-left: 1.25rem;
		color: var(--color-text-secondary);
		font-size: 13px;
		line-height: 1.6;
	}

	.sticky-card__price-note {
		font-size: 11px;
		color: var(--color-text-tertiary);
		margin: 0 0 12px;
		line-height: 1.5;
	}

	.cta-primary--link {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.tour-detail .layout {
			grid-template-columns: 1fr;
		}

		.tour-detail .highlights,
		.tour-detail .includes-grid,
		.tour-detail .info-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
