---
import type { TourDetail } from '../../types/tour';
import { supportsInstantBook, contactHrefForTour } from '../../lib/booking';
import TourImage from '../TourImage.astro';

type Props = { tour: TourDetail };

const { tour } = Astro.props;
const instantBook = supportsInstantBook(tour);
---

<article class="detail">
	<header class="detail__hero">
		<div class="detail__hero-media">
			<TourImage photo={tour.image} layout="hero" priority class="detail__hero-picture" />
			<div class="detail__hero-overlay" aria-hidden="true"></div>
		</div>
		<div class="detail__hero-text">
			<p class="detail__eyebrow type-label">{tour.availability}</p>
			<h1 class="detail__title">{tour.title}</h1>
			<p class="detail__tagline">{tour.tagline}</p>
			<p class="detail__schedule">{tour.scheduleLabel}</p>
		</div>
	</header>

	<div class="detail__content">
		<section class="block" aria-labelledby="overview-heading">
			<h2 id="overview-heading" class="block__h">Tour overview &amp; highlights</h2>
			<p class="block__p">{tour.overviewHighlights}</p>
		</section>

		<section class="meta-grid" aria-label="Schedule summary">
			<div class="meta-card">
				<h3 class="meta-card__label type-label">Departure</h3>
				<p class="meta-card__val">{tour.departure}</p>
			</div>
			<div class="meta-card">
				<h3 class="meta-card__label type-label">Duration</h3>
				<p class="meta-card__val">{tour.duration}</p>
			</div>
			<div class="meta-card">
				<h3 class="meta-card__label type-label">Return</h3>
				<p class="meta-card__val">{tour.returnTime}</p>
			</div>
		</section>

		<section class="block" aria-labelledby="itin-heading">
			<h2 id="itin-heading" class="block__h">{tour.itineraryLabel}</h2>
			<ol class="itin-list">
				{tour.itinerary.map((step) => (
					<li>{step}</li>
				))}
			</ol>
		</section>

		<div class="triple">
			<section class="block block--tight" aria-labelledby="meet-heading">
				<h2 id="meet-heading" class="block__h">Meeting point</h2>
				<p class="block__p">{tour.meetingPoint}</p>
			</section>
			<section class="block block--tight" aria-labelledby="wx-heading">
				<h2 id="wx-heading" class="block__h">Weather</h2>
				<p class="block__p">{tour.weather}</p>
			</section>
			<section class="block block--tight" aria-labelledby="safe-heading">
				<h2 id="safe-heading" class="block__h">Important info &amp; safety</h2>
				<p class="block__p">{tour.importantInfo}</p>
			</section>
		</div>

		<section class="block" aria-labelledby="bring-heading">
			<h2 id="bring-heading" class="block__h">What to bring</h2>
			<ul class="bullet">
				{tour.whatToBring.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		</section>

		<div class="split">
			<section class="block block--tight" aria-labelledby="inc-heading">
				<h2 id="inc-heading" class="block__h">What&apos;s included</h2>
				<ul class="bullet">
					{tour.included.map((item) => (
						<li>{item}</li>
					))}
				</ul>
			</section>
			<section class="block block--tight" aria-labelledby="noinc-heading">
				<h2 id="noinc-heading" class="block__h">Not included</h2>
				<ul class="bullet">
					{tour.notIncluded.map((item) => (
						<li>{item}</li>
					))}
				</ul>
			</section>
		</div>

		<section class="block block--price" aria-labelledby="price-heading">
			<h2 id="price-heading" class="block__h">Price breakdown</h2>
			<p class="block__p">{tour.priceNotes}</p>
			<p class="block__note">
				<strong>Cave &amp; park tickets:</strong> {tour.caveTicketNote}
			</p>
		</section>

		{
			tour.groupSale && (
				<section class="block block--group" aria-labelledby="group-heading">
					<h2 id="group-heading" class="block__h">
						Group bookings
					</h2>
					<p class="block__p">{tour.groupSale}</p>
				</section>
			)
		}

		<section class="block" aria-labelledby="gallery-heading">
			<h2 id="gallery-heading" class="block__h">Gallery</h2>
			<div class="gallery">
				{tour.gallery.map((img) => (
					<figure class="gallery__fig">
						<TourImage photo={img} layout="gallery" fadeIn class="gallery__picture" />
					</figure>
				))}
			</div>
		</section>

		<section class="block" aria-labelledby="disc-heading">
			<h2 id="disc-heading" class="block__h">Disclaimers</h2>
			<ul class="bullet">
				{tour.disclaimers.map((d) => (
					<li>{d}</li>
				))}
			</ul>
		</section>

		<div class="cta-bar">
			{
				instantBook ? (
					<form class="booking-form" data-tour-id={tour.slug}>
						<button type="submit" class="cta-bar__btn" aria-label={`Book now: ${tour.title}`}>
							Book now
						</button>
					</form>
				) : (
					<a class="cta-bar__btn cta-bar__btn--link" href={contactHrefForTour(tour)}>
						Request a quote
					</a>
				)
			}
			<a class="cta-bar__back" href="/tours">← All tours</a>
		</div>
	</div>
</article>

<style>
	.detail {
		background: var(--color-base);
	}

	.detail__hero {
		position: relative;
		min-height: 320px;
		color: var(--color-chrome-text);
	}

	.detail__hero-media {
		position: absolute;
		inset: 0;
	}

	.detail__hero-media :global(.detail__hero-picture) {
		width: 100%;
		height: 100%;
	}

	.detail__hero-media :global(.tour-image__img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.detail__hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, var(--color-overlay-strong), var(--color-overlay-mid));
	}

	.detail__hero-text {
		position: relative;
		z-index: 1;
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--section-padding-y) var(--page-padding-x) 2.5rem;
	}

	.detail__eyebrow {
		margin: 0 0 0.5rem;
		font-size: var(--text-xs);
		color: var(--color-chrome-link);
	}

	.detail__title {
		margin: 0 0 0.35rem;
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: var(--font-weight-bold);
		line-height: 1.15;
	}

	.detail__tagline {
		margin: 0 0 0.5rem;
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--color-chrome-text-muted);
	}

	.detail__schedule {
		margin: 0;
		font-size: 0.9375rem;
		color: var(--color-chrome-text-muted);
	}

	.detail__content {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--section-padding-y) var(--page-padding-x) var(--page-padding-bottom);
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.block__h {
		margin: 0 0 0.75rem;
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: var(--font-weight-bold);
		color: var(--color-nav);
	}

	.block__p {
		margin: 0;
		color: var(--color-muted);
		line-height: 1.65;
	}

	.block__muted {
		margin: 0 0 1rem;
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	.block__note {
		margin: 1rem 0 0;
		padding: 1rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		font-size: 0.9375rem;
		line-height: 1.55;
		color: var(--color-text);
	}

	.meta-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 1rem;
	}

	.meta-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: 1rem 1.15rem;
	}

	.meta-card__label {
		margin: 0 0 0.35rem;
		font-size: var(--text-xs);
		color: var(--color-muted);
	}

	.meta-card__val {
		margin: 0;
		font-family: var(--font-display);
		font-weight: var(--font-weight-semibold);
		color: var(--color-nav);
		line-height: 1.4;
	}

	.itin-list {
		margin: 0;
		padding-left: 1.25rem;
		color: var(--color-muted);
		line-height: 1.65;
	}

	.itin-list li {
		margin-bottom: 0.35rem;
	}

	.triple {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.5rem;
	}

	.split {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
		align-items: start;
	}

	.bullet {
		margin: 0;
		padding-left: 1.25rem;
		color: var(--color-muted);
		line-height: 1.55;
	}

	.block--price {
		background: var(--color-surface);
		padding: 1.5rem;
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
	}

	.block--group {
		background: linear-gradient(135deg, var(--color-panel-muted) 0%, var(--color-surface) 100%);
		padding: 1.5rem;
		border-radius: var(--radius);
		border: 1px solid var(--color-panel-border);
	}

	.gallery {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem;
	}

	.gallery__fig {
		margin: 0;
		border-radius: 8px;
		overflow: hidden;
		aspect-ratio: 3 / 2;
	}

	.gallery__fig :global(.gallery__picture) {
		width: 100%;
		height: 100%;
	}

	@media (max-width: 640px) {
		.gallery {
			grid-template-columns: 1fr;
		}
	}

	.cta-bar {
		padding: 1.5rem;
		background: var(--color-chrome-bg);
		color: var(--color-chrome-text-muted);
		border-radius: var(--radius);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: flex-start;
	}

	.cta-bar__btn {
		appearance: none;
		border: none;
		cursor: pointer;
		min-height: var(--touch-min);
		padding: 0.75rem 1.5rem;
		border-radius: 8px;
		background: var(--color-cta);
		color: var(--color-cta-text);
		font-weight: var(--font-weight-bold);
		font-size: var(--text-base);
	}

	.cta-bar__btn:hover {
		background: var(--color-cta-hover);
		color: var(--color-cta-text);
	}

	.cta-bar__btn--link {
		display: inline-block;
		text-decoration: none;
		text-align: center;
	}

	.cta-bar__back {
		color: var(--color-chrome-link);
		font-weight: 600;
		text-decoration: none;
	}

	.cta-bar__back:hover {
		color: var(--color-brand-on-primary);
	}
</style>
