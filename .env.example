# Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Create Products → Prices in Stripe Dashboard; use one Price ID per tour:
STRIPE_PRICE_BLUE_CAVE_ADVENTURE=price_...
STRIPE_PRICE_PRIVATE_SPLIT_COAST=price_...
STRIPE_PRICE_SPLIT_ISLAND_HOPPING=price_...

# Optional: production site URL for canonical links when deploying
# PUBLIC_SITE_URL=https://your-domain.com
