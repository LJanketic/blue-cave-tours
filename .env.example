# Site URL (required for production canonical links on Netlify)
PUBLIC_SITE_URL=https://your-domain.com

# Checkout:
# - Omit both vars → dev uses mock; production shows "Request a quote" unless Stripe is configured
# - CHECKOUT_MODE=mock → always demo redirect (staging only)
# - CHECKOUT_MODE=stripe + STRIPE_SECRET_KEY → live Stripe Checkout
# CHECKOUT_MODE=stripe

# Stripe — https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...

# One env var per tour slug (uppercase, hyphens → underscores):
# STRIPE_PRICE_BLUE_CAVE_HVAR_5_ISLANDS=price_...
# STRIPE_PRICE_GOLDEN_HORN_BRAC_HVAR=price_...
