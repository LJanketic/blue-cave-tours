# Public site URL (canonical links, PayPal return URLs)
# PUBLIC_SITE_URL=https://bluecavetours.com

# Payment provider: demo forces contact-only booking (ignores PayPal/Teya creds)
# PAYMENT_PROVIDER=demo

# PayPal — sandbox or live (https://developer.paypal.com/dashboard/)
# PUBLIC_PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox
# PAYPAL_WEBHOOK_ID=

# Teya Hosted Checkout — staging uses *.teya.xyz (https://docs.teya.com/)
# Requires Online Payments on your Teya account (contact Teya support).
# TEYA_CLIENT_ID=
# TEYA_CLIENT_SECRET=
# TEYA_MODE=sandbox
# TEYA_STORE_ID=

# Supabase — EU project (service role is server-only, never expose to client)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# SMTP — cPanel / existing provider (G4)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=info@bluecavetours.com
# SMTP_TO=info@bluecavetours.com
