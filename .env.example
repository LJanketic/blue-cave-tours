# Checkout: omit CHECKOUT_MODE or set to `mock` for demo redirects (no Stripe calls).
# Set to `stripe` and add keys when ready.
# CHECKOUT_MODE=mock

# Stripe — only needed when CHECKOUT_MODE=stripe (or unset with a secret key present)
# Get test keys from https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...

# One env var per tour slug, uppercase with underscores:
# slug `blue-cave-hvar-5-islands` → STRIPE_PRICE_BLUE_CAVE_HVAR_5_ISLANDS=price_...
# STRIPE_PRICE_BLUE_CAVE_HVAR_5_ISLANDS=price_...
# STRIPE_PRICE_GOLDEN_HORN_BRAC_HVAR=price_...
# (add each product you sell in Stripe Dashboard)

# Optional: production site URL for canonical links when deploying
# PUBLIC_SITE_URL=https://your-domain.com
